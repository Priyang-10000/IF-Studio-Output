                      {
                        "type": "container",
                        "id": "tag190",
                        "selfContain": false,
                        "backgroundImage": {},
                        "children": [
                          {
                            "type": "svg",
                            "id": "tag191",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 540 240\" width=\"100%\" style=\"overflow:visible;\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"lineGrad1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#3b82f6\" stop-opacity=\"0.25\"></stop>\n              <stop offset=\"100%\" stop-color=\"#3b82f6\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#8b5cf6\" stop-opacity=\"0.2\"></stop>\n              <stop offset=\"100%\" stop-color=\"#8b5cf6\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"2\" result=\"blur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"blur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n\n          <!-- Grid lines -->\n          <line x1=\"40\" y1=\"10\" x2=\"40\" y2=\"200\" stroke=\"#1e2d4a\" stroke-width=\"1\"></line>\n          <line x1=\"40\" y1=\"200\" x2=\"530\" y2=\"200\" stroke=\"#1e2d4a\" stroke-width=\"1\"></line>\n          <line x1=\"40\" y1=\"10\" x2=\"530\" y2=\"10\" stroke=\"#1e2d4a\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\"></line>\n          <line x1=\"40\" y1=\"57.5\" x2=\"530\" y2=\"57.5\" stroke=\"#1e2d4a\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\"></line>\n          <line x1=\"40\" y1=\"105\" x2=\"530\" y2=\"105\" stroke=\"#1e2d4a\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\"></line>\n          <line x1=\"40\" y1=\"152.5\" x2=\"530\" y2=\"152.5\" stroke=\"#1e2d4a\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\"></line>\n\n          <!-- Y-axis labels -->\n          <text x=\"35\" y=\"14\" text-anchor=\"end\" fill=\"#475569\" font-size=\"9\" font-family=\"JetBrains Mono\">$200M</text>\n          <text x=\"35\" y=\"61.5\" text-anchor=\"end\" fill=\"#475569\" font-size=\"9\" font-family=\"JetBrains Mono\">$150M</text>\n          <text x=\"35\" y=\"109\" text-anchor=\"end\" fill=\"#475569\" font-size=\"9\" font-family=\"JetBrains Mono\">$100M</text>\n          <text x=\"35\" y=\"156.5\" text-anchor=\"end\" fill=\"#475569\" font-size=\"9\" font-family=\"JetBrains Mono\">$50M</text>\n          <text x=\"35\" y=\"204\" text-anchor=\"end\" fill=\"#475569\" font-size=\"9\" font-family=\"JetBrains Mono\">$0</text>\n\n          <!-- X-axis: 2020, 2021, 2022, 2023, 2024 -->\n          <!-- x positions: 2020=80, 2021=175, 2022=270, 2023=365, 2024=460 -->\n          <text x=\"80\" y=\"218\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"9\">2020</text>\n          <text x=\"175\" y=\"218\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"9\">2021</text>\n          <text x=\"270\" y=\"218\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"9\">2022</text>\n          <text x=\"365\" y=\"218\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"9\">2023</text>\n          <text x=\"460\" y=\"218\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"9\">2024</text>\n\n          <!-- === LINE 1: OpenAI models ($M) ===\n            2020: GPT-3 ~12M → y=200-(12/200)*190=200-11.4=188.6\n            2021: Codex ~20M → y=200-(20/200)*190=181\n            2022: GPT-3.5 ~6M (fine-tune) let's use InstructGPT ~5M → y=195.25\n            2023: GPT-4 ~100M → y=200-(100/200)*190=105\n            2024: GPT-4o ~60M (inference scale est.) let's say $80M → y=200-(80/200)*190=124\n          Actually let me use: GPT-3=12, Codex=20, GPT3.5=30, GPT4=100, GPT4o+next=180\n          y calc: y = 200 - (val/200)*190\n          12 → 188.6 | 20 → 181 | 30 → 171.5 | 100 → 105 | 180 → 29\n          -->\n          <!-- Fill area under line 1 -->\n          <path d=\"M80,188.6 L175,181 L270,171.5 L365,105 L460,29 L460,200 L80,200 Z\" fill=\"url(#lineGrad1)\"></path>\n          <!-- Line 1 -->\n          <polyline points=\"80,188.6 175,181 270,171.5 365,105 460,29\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\" filter=\"url(#glow)\"></polyline>\n          <!-- Dots line 1 -->\n          <circle cx=\"80\" cy=\"188.6\" r=\"4\" fill=\"#3b82f6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"175\" cy=\"181\" r=\"4\" fill=\"#3b82f6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"270\" cy=\"171.5\" r=\"4\" fill=\"#3b82f6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"365\" cy=\"105\" r=\"4\" fill=\"#3b82f6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"460\" cy=\"29\" r=\"5\" fill=\"#3b82f6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n\n          <!-- === LINE 2: Google/DeepMind models\n            2020: AlphaFold2 ~20 → 181\n            2021: LaMDA ~60 → 200-(60/200)*190=143\n            2022: PaLM 540B ~35 → 200-(35/200)*190=166.75 (compute est)\n            2023: Gemini Ultra ~90 → 200-(90/200)*190=114.5\n            2024: Gemini 1.5 Pro ~130 → 200-(130/200)*190=76.5\n          -->\n          <path d=\"M80,181 L175,143 L270,166.75 L365,114.5 L460,76.5 L460,200 L80,200 Z\" fill=\"url(#lineGrad2)\"></path>\n          <polyline points=\"80,181 175,143 270,166.75 365,114.5 460,76.5\" fill=\"none\" stroke=\"#8b5cf6\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\" stroke-dasharray=\"6 3\" filter=\"url(#glow)\"></polyline>\n          <circle cx=\"80\" cy=\"181\" r=\"4\" fill=\"#8b5cf6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"175\" cy=\"143\" r=\"4\" fill=\"#8b5cf6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"270\" cy=\"166.75\" r=\"4\" fill=\"#8b5cf6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"365\" cy=\"114.5\" r=\"4\" fill=\"#8b5cf6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"460\" cy=\"76.5\" r=\"5\" fill=\"#8b5cf6\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n\n          <!-- Legend -->\n          <line x1=\"50\" y1=\"235\" x2=\"70\" y2=\"235\" stroke=\"#3b82f6\" stroke-width=\"2.5\"></line>\n          <circle cx=\"60\" cy=\"235\" r=\"3\" fill=\"#3b82f6\"></circle>\n          <text x=\"74\" y=\"238.5\" fill=\"#94a3b8\" font-size=\"9\">OpenAI Models</text>\n          <line x1=\"180\" y1=\"235\" x2=\"200\" y2=\"235\" stroke=\"#8b5cf6\" stroke-width=\"2.5\" stroke-dasharray=\"4 2\"></line>\n          <circle cx=\"190\" cy=\"235\" r=\"3\" fill=\"#8b5cf6\"></circle>\n          <text x=\"204\" y=\"238.5\" fill=\"#94a3b8\" font-size=\"9\">Google/DeepMind</text>\n\n          <!-- Annotations -->\n          <rect x=\"340\" y=\"88\" width=\"70\" height=\"22\" rx=\"4\" fill=\"rgba(59,130,246,0.15)\" stroke=\"rgba(59,130,246,0.3)\" stroke-width=\"1\"></rect>\n          <text x=\"375\" y=\"103\" text-anchor=\"middle\" fill=\"#3b82f6\" font-size=\"8\" font-weight=\"700\">GPT-4 ~$100M</text>\n        </svg>",
