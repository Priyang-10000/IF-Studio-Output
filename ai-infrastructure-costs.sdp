                        "svgText": "<svg width=\"200\" height=\"140\" viewBox=\"0 0 200 140\" xmlns=\"http://www.w3.org/2000/svg\">\n        <!-- Server rack 1 -->\n        <rect x=\"10\" y=\"20\" width=\"50\" height=\"100\" rx=\"4\" fill=\"#0d1526\" stroke=\"#1e2d4a\" stroke-width=\"1\"></rect>\n        <rect x=\"15\" y=\"28\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(59,130,246,0.3)\" stroke=\"rgba(59,130,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"15\" y=\"40\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(59,130,246,0.3)\" stroke=\"rgba(59,130,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"15\" y=\"52\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(139,92,246,0.3)\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"15\" y=\"64\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(139,92,246,0.3)\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"15\" y=\"76\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(6,182,212,0.3)\" stroke=\"rgba(6,182,212,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"15\" y=\"88\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(16,185,129,0.3)\" stroke=\"rgba(16,185,129,0.5)\" stroke-width=\"0.5\"></rect>\n        <circle cx=\"47\" cy=\"32\" r=\"2\" fill=\"#3b82f6\" opacity=\"0.9\">\n          <animate attributeName=\"opacity\" values=\"0.9;0.3;0.9\" dur=\"1.5s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"47\" cy=\"44\" r=\"2\" fill=\"#3b82f6\" opacity=\"0.7\">\n          <animate attributeName=\"opacity\" values=\"0.7;0.2;0.7\" dur=\"1.8s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"47\" cy=\"56\" r=\"2\" fill=\"#8b5cf6\" opacity=\"0.9\">\n          <animate attributeName=\"opacity\" values=\"0.9;0.3;0.9\" dur=\"2.1s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"47\" cy=\"68\" r=\"2\" fill=\"#8b5cf6\" opacity=\"0.6\">\n          <animate attributeName=\"opacity\" values=\"0.6;0.1;0.6\" dur=\"1.3s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"47\" cy=\"80\" r=\"2\" fill=\"#06b6d4\" opacity=\"0.9\">\n          <animate attributeName=\"opacity\" values=\"0.9;0.4;0.9\" dur=\"1.7s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"47\" cy=\"92\" r=\"2\" fill=\"#10b981\" opacity=\"0.8\">\n          <animate attributeName=\"opacity\" values=\"0.8;0.2;0.8\" dur=\"2.3s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <!-- Server rack 2 -->\n        <rect x=\"75\" y=\"20\" width=\"50\" height=\"100\" rx=\"4\" fill=\"#0d1526\" stroke=\"#1e2d4a\" stroke-width=\"1\"></rect>\n        <rect x=\"80\" y=\"28\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(16,185,129,0.3)\" stroke=\"rgba(16,185,129,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"80\" y=\"40\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(245,158,11,0.3)\" stroke=\"rgba(245,158,11,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"80\" y=\"52\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(59,130,246,0.3)\" stroke=\"rgba(59,130,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"80\" y=\"64\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(239,68,68,0.3)\" stroke=\"rgba(239,68,68,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"80\" y=\"76\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(139,92,246,0.3)\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"80\" y=\"88\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(6,182,212,0.3)\" stroke=\"rgba(6,182,212,0.5)\" stroke-width=\"0.5\"></rect>\n        <circle cx=\"112\" cy=\"32\" r=\"2\" fill=\"#10b981\" opacity=\"0.9\">\n          <animate attributeName=\"opacity\" values=\"0.9;0.3;0.9\" dur=\"2s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <circle cx=\"112\" cy=\"44\" r=\"2\" fill=\"#f59e0b\">\n          <animate attributeName=\"opacity\" values=\"1;0.3;1\" dur=\"1.4s\" repeatCount=\"indefinite\"></animate>\n        </circle>\n        <!-- Server rack 3 -->\n        <rect x=\"140\" y=\"20\" width=\"50\" height=\"100\" rx=\"4\" fill=\"#0d1526\" stroke=\"#1e2d4a\" stroke-width=\"1\"></rect>\n        <rect x=\"145\" y=\"28\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(236,72,153,0.3)\" stroke=\"rgba(236,72,153,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"145\" y=\"40\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(59,130,246,0.3)\" stroke=\"rgba(59,130,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"145\" y=\"52\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(16,185,129,0.3)\" stroke=\"rgba(16,185,129,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"145\" y=\"64\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(6,182,212,0.3)\" stroke=\"rgba(6,182,212,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"145\" y=\"76\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(245,158,11,0.3)\" stroke=\"rgba(245,158,11,0.5)\" stroke-width=\"0.5\"></rect>\n        <rect x=\"145\" y=\"88\" width=\"40\" height=\"8\" rx=\"2\" fill=\"rgba(139,92,246,0.3)\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"0.5\"></rect>\n        <!-- Connecting lines / network -->\n        <line x1=\"60\" y1=\"70\" x2=\"75\" y2=\"70\" stroke=\"rgba(59,130,246,0.4)\" stroke-width=\"1\" stroke-dasharray=\"3 2\"></line>\n        <line x1=\"125\" y1=\"70\" x2=\"140\" y2=\"70\" stroke=\"rgba(16,185,129,0.4)\" stroke-width=\"1\" stroke-dasharray=\"3 2\"></line>\n        <!-- Floor -->\n        <rect x=\"5\" y=\"122\" width=\"190\" height=\"4\" rx=\"2\" fill=\"rgba(30,45,74,0.8)\"></rect>\n        <!-- Labels -->\n        <text x=\"35\" y=\"137\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"7\" font-family=\"Inter\">H100 Cluster</text>\n        <text x=\"100\" y=\"137\" text-anchor=\"middle\" fill=\"#475569\" font-size=\"7\" font-family=\"Inter\">Networking</text>\n        <text x=\"165\" y=\"137\" text-anchor