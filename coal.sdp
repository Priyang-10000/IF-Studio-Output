                                "dataset": "",
                                "field": "",
                                "svgText": "<svg width=\"170\" height=\"170\" viewBox=\"0 0 170 170\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <filter id=\"glow\">\n                <feGaussianBlur stdDeviation=\"2\" result=\"coloredBlur\"></feGaussianBlur>\n                <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n              </filter>\n            </defs>\n            <!-- Total circle bg -->\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"22\"></circle>\n            <!-- Electricity: 58% = 209deg. offset=0 -->\n            <!-- Steel/Metal: 17% = 61deg. offset=209 -->\n            <!-- Cement: 8% = 29deg. offset=270 -->\n            <!-- Heat/Other Ind: 12% = 43deg. offset=299 -->\n            <!-- Residential: 5% = 18deg. offset=342 -->\n            <!-- Circumference = 2*pi*65 = 408.4 -->\n            <!-- 58% = 236.9, 17% = 69.4, 8% = 32.7, 12% = 49.0, 5% = 20.4 -->\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"#7c3aed\" stroke-width=\"22\" stroke-dasharray=\"236.9 408.4\" stroke-dashoffset=\"0\" transform=\"rotate(-90 85 85)\" filter=\"url(#glow)\"></circle>\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"#2563eb\" stroke-width=\"22\" stroke-dasharray=\"69.4 408.4\" stroke-dashoffset=\"-236.9\" transform=\"rotate(-90 85 85)\"></circle>\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"#0891b2\" stroke-width=\"22\" stroke-dasharray=\"32.7 408.4\" stroke-dashoffset=\"-306.3\" transform=\"rotate(-90 85 85)\"></circle>\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"#059669\" stroke-width=\"22\" stroke-dasharray=\"49.0 408.4\" stroke-dashoffset=\"-339\" transform=\"rotate(-90 85 85)\"></circle>\n            <circle cx=\"85\" cy=\"85\" r=\"65\" fill=\"none\" stroke=\"#d97706\" stroke-width=\"22\" stroke-dasharray=\"20.4 408.4\" stroke-dashoffset=\"-388\" transform=\"rotate(-90 85 85)\"></circle>\n            <!-- Center text -->\n            <text x=\"85\" y=\"80\" text-anchor=\"middle\" font-size=\"11\" fill=\"#94b8d8\" font-weight=\"600\">Global</text>\n            <text x=\"85\" y=\"96\" text-anchor=\"middle\" font-size=\"9\" fill=\"#5a7a95\">Coal Use</text>\n          </svg>",
