                            "id": "tag147",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 580 190\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" style=\"overflow:visible;\">\n          <!-- Area fill -->\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#16a34a\" stop-opacity=\"0.3\"></stop>\n              <stop offset=\"100%\" stop-color=\"#16a34a\" stop-opacity=\"0.02\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Data: 2000=105, 2002=110, 2004=120, 2006=133, 2008=140, 2010=148, 2012=157, 2014=160, 2016=155, 2018=158, 2020=152, 2021=160, 2022=162, 2023=161 -->\n          <!-- Scaled: min=105, max=175, range=70, height=160 -->\n          <!-- x: 14 points across 580px, step=580/13=44.6 -->\n          <!-- y formula: 160 - ((val-105)/70)*160 -->\n          <!-- 2000=0: 160-0=160 -->\n          <!-- 2002=110: 160-(5/70*160)=160-11.4=148.6 -->\n          <!-- 2004=120: 160-(15/70*160)=160-34.3=125.7 -->\n          <!-- 2006=133: 160-(28/70*160)=160-64=96 -->\n          <!-- 2008=140: 160-(35/70*160)=160-80=80 -->\n          <!-- 2010=148: 160-(43/70*160)=160-98.3=61.7 -->\n          <!-- 2012=157: 160-(52/70*160)=160-118.9=41.1 -->\n          <!-- 2014=160: 160-(55/70*160)=160-125.7=34.3 -->\n          <!-- 2016=155: 160-(50/70*160)=160-114.3=45.7 -->\n          <!-- 2018=158: 160-(53/70*160)=160-121.1=38.9 -->\n          <!-- 2020=152: 160-(47/70*160)=160-107.4=52.6 -->\n          <!-- 2021=160: 160-(55/70*160)=160-125.7=34.3 -->\n          <!-- 2022=162: 160-(57/70*160)=160-130.3=29.7 -->\n          <!-- 2023=161: 160-(56/70*160)=160-128=32 -->\n          <path d=\"M0,160 L44.6,148.6 L89.2,125.7 L133.8,96 L178.4,80 L223,61.7 L267.6,41.1 L312.2,34.3 L356.8,45.7 L401.4,38.9 L446,52.6 L490.6,34.3 L535.2,29.7 L580,32 L580,160 Z\" fill=\"url(#lineGrad)\"></path>\n          <path d=\"M0,160 L44.6,148.6 L89.2,125.7 L133.8,96 L178.4,80 L223,61.7 L267.6,41.1 L312.2,34.3 L356.8,45.7 L401.4,38.9 L446,52.6 L490.6,34.3 L535.2,29.7 L580,32\" fill=\"none\" stroke=\"#22c55e\" stroke-width=\"2.5\" stroke-linejoin=\"round\"></path>\n          <!-- Points -->\n          <circle cx=\"0\" cy=\"160\" r=\"3.5\" fill=\"#22c55e\"></circle>\n          <circle cx=\"89.2\" cy=\"125.7\" r=\"3.5\" fill=\"#22c55e\"></circle>\n          <circle cx=\"178.4\" cy=\"80\" r=\"3.5\" fill=\"#22c55e\"></circle>\n          <circle cx=\"267.6\" cy=\"41.1\" r=\"3.5\" fill=\"#22c55e\"></circle>\n          <circle cx=\"312.2\" cy=\"34.3\" r=\"4\" fill=\"#4ade80\" stroke=\"#22c55e\" stroke-width=\"1.5\"></circle>\n          <circle cx=\"446\" cy=\"52.6\" r=\"3.5\" fill=\"#22c55e\"></circle>\n          <circle cx=\"580\" cy=\"32\" r=\"4\" fill=\"#4ade80\" stroke=\"#22c55e\" stroke-width=\"1.5\"></circle>\n          <!-- Labels -->\n          <text x=\"0\" y=\"177\" font-size=\"9\" fill=\"#4a7a60\" text-anchor=\"middle\">2000</text>\n          <text x=\"178.4\" y=\"177\" font-size=\"9\" fill=\"#4a7a60\" text-anchor=\"middle\">2008</text>\n          <text x=\"312.2\" y=\"177\" font-size=\"9\" fill=\"#4a7a60\" text-anchor=\"middle\">2014</text>\n          <text x=\"446\" y=\"177\" font-size=\"9\" fill=\"#4a7a60\" text-anchor=\"middle\">2020</text>\n          <text x=\"580\" y=\"177\" font-size=\"9\" fill=\"#4a7a60\" text-anchor=\"middle\">2023</text>\n          <!-- Peak annotation -->\n          <line x1=\"535.2\" y1=\"29.7\" x2=\"535.2\" y2=\"10\" stroke=\"#f59e0b\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n          <text x=\"535.2\" y=\"8\" font-size=\"8.5\" fill=\"#f59e0b\" text-anchor=\"middle\">Peak 162 EJ</text>\n        </svg>",
