                        "children": [
                          {
                            "type": "svg",
                            "id": "tag198",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"180\" height=\"200\" viewBox=\"0 0 180 200\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Ground layers -->\n          <!-- Peat -->\n          <rect x=\"10\" y=\"10\" width=\"160\" height=\"38\" rx=\"4\" fill=\"#3d5a1e\" stroke=\"#4a7a28\" stroke-width=\"1\"></rect>\n          <text x=\"90\" y=\"24\" text-anchor=\"middle\" font-size=\"9\" fill=\"#86efac\" font-weight=\"600\">PEAT</text>\n          <text x=\"90\" y=\"35\" text-anchor=\"middle\" font-size=\"7.5\" fill=\"#4ade80\">Recent → 300 million yrs ago</text>\n          <!-- Arrow -->\n          <path d=\"M85,48 L85,54 L80,54 L90,62 L100,54 L95,54 L95,48 Z\" fill=\"#3a7bbf\" opacity=\"0.7\"></path>\n          <!-- Lignite -->\n          <rect x=\"10\" y=\"62\" width=\"160\" height=\"38\" rx=\"4\" fill=\"#2d3f20\" stroke=\"#3a5a28\" stroke-width=\"1\"></rect>\n          <text x=\"90\" y=\"76\" text-anchor=\"middle\" font-size=\"9\" fill=\"#86efac\" font-weight=\"600\">LIGNITE (Brown Coal)</text>\n          <text x=\"90\" y=\"87\" text-anchor=\"middle\" font-size=\"7.5\" fill=\"#4ade80\">~60-70 MJ/kg · 25-35% Carbon</text>\n          <!-- Arrow -->\n          <path d=\"M85,100 L85,106 L80,106 L90,114 L100,106 L95,106 L95,100 Z\" fill=\"#3a7bbf\" opacity=\"0.7\"></path>\n          <!-- Sub-bituminous -->\n          <rect x=\"10\" y=\"114\" width=\"160\" height=\"38\" rx=\"4\" fill=\"#1e2e2a\" stroke=\"#2a5040\" stroke-width=\"1\"></rect>\n          <text x=\"90\" y=\"128\" text-anchor=\"middle\" font-size=\"9\" fill=\"#7dd3fc\" font-weight=\"600\">SUB-BITUMINOUS</text>\n          <text x=\"90\" y=\"139\" text-anchor=\"middle\" font-size=\"7.5\" fill=\"#5ba4e6\">~200 million yrs · 45-65% C</text>\n          <!-- Arrow -->\n          <path d=\"M85,152 L85,158 L80,158 L90,166 L100,158 L95,158 L95,152 Z\" fill=\"#5ba4e6\" opacity=\"0.7\"></path>\n          <!-- Bituminous -->\n          <rect x=\"10\" y=\"166\" width=\"160\" height=\"18\" rx=\"4\" fill=\"#0f1e3a\" stroke=\"#1e3a6a\" stroke-width=\"1\"></rect>\n          <text x=\"90\" y=\"178\" text-anchor=\"middle\" font-size=\"8\" fill=\"#7eb8f7\" font-weight=\"600\">BITUMINOUS · 65-85% C</text>\n          <!-- Anthracite bar -->\n          <rect x=\"10\" y=\"186\" width=\"160\" height=\"12\" rx=\"4\" fill=\"#080c18\" stroke=\"#3a7bbf\" stroke-width=\"1.5\"></rect>\n          <text x=\"90\" y=\"195\" text-anchor=\"middle\" font-size=\"7.5\" fill=\"#5ba4e6\" font-weight=\"700\">ANTHRACITE · 86-97% C · Highest Quality</text>\n          <!-- Pressure/Heat arrows on sides -->\n          <text x=\"4\" y=\"115\" font-size=\"7\" fill=\"#3a5870\" transform=\"rotate(-90 4 120)\" text-anchor=\"middle\">PRESSURE + TIME</text>\n          <text x=\"178\" y=\"115\" font-size=\"7\" fill=\"#3a5870\" transform=\"rotate(90 178 120)\" text-anchor=\"middle\">HEAT + DEPTH</text>\n        </svg>",
                            "record": 0,
