                  {
                    "type": "container",
                    "id": "tag114",
                    "selfContain": false,
                    "backgroundImage": {},
                    "children": [
                      {
                        "type": "svg",
                        "id": "tag115",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 740 260\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#FFD700\" stop-opacity=\"0.25\"></stop>\n            <stop offset=\"100%\" stop-color=\"#FFD700\" stop-opacity=\"0\"></stop>\n          </linearGradient>\n          <linearGradient id=\"lineStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#B8860B\"></stop>\n            <stop offset=\"40%\" stop-color=\"#FFD700\"></stop>\n            <stop offset=\"100%\" stop-color=\"#FFA500\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Grid -->\n        <line x1=\"60\" y1=\"20\" x2=\"60\" y2=\"210\" class=\"axis-line\"></line>\n        <line x1=\"60\" y1=\"210\" x2=\"720\" y2=\"210\" class=\"axis-line\"></line>\n        <line x1=\"60\" y1=\"160\" x2=\"720\" y2=\"160\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"110\" x2=\"720\" y2=\"110\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"60\" x2=\"720\" y2=\"60\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"20\" x2=\"720\" y2=\"20\" class=\"grid-line\"></line>\n\n        <!-- Y labels: 0→3200, height=190px, 1px=16.84/unit -->\n        <text x=\"50\" y=\"214\" class=\"axis-label\" text-anchor=\"end\">$0</text>\n        <text x=\"50\" y=\"164\" class=\"axis-label\" text-anchor=\"end\">$800</text>\n        <text x=\"50\" y=\"114\" class=\"axis-label\" text-anchor=\"end\">$1,600</text>\n        <text x=\"50\" y=\"64\" class=\"axis-label\" text-anchor=\"end\">$2,400</text>\n        <text x=\"50\" y=\"24\" class=\"axis-label\" text-anchor=\"end\">$3,200</text>\n\n        <!--\n          Years: 1970,1975,1980,1985,1990,1995,2000,2005,2010,2015,2020,2025\n          X range: 60→720 = 660px for 11 intervals (12 points)\n          interval = 60px\n          Prices (approx): 36,160,615,317,385,384,279,445,1225,1160,1770,3100\n          Y = 210 - (price/3200)*190\n        -->\n        <!-- $36 → y=207.9 --><!-- $160 → y=200.5 --><!-- $615 → y=173.5 --><!-- $317 → y=191.2 -->\n        <!-- $385 → y=187.2 --><!-- $384 → y=187.3 --><!-- $279 → y=193.5 --><!-- $445 → y=183.6 -->\n        <!-- $1225 → y=137.3 --><!-- $1160 → y=141.1 --><!-- $1770 → y=104.9 --><!-- $3100 → y=25.6 -->\n\n        <!-- Area fill -->\n        <path d=\"\n          M60,207.9\n          L120,200.5\n          L180,173.5\n          L240,191.2\n          L300,187.2\n          L360,187.3\n          L420,193.5\n          L480,183.6\n          L540,137.3\n          L600,141.1\n          L660,104.9\n          L720,25.6\n          L720,210 L60,210 Z\" fill=\"url(#lineGrad)\"></path>\n\n        <!-- Line -->\n        <polyline points=\"60,207.9 120,200.5 180,173.5 240,191.2 300,187.2 360,187.3 420,193.5 480,183.6 540,137.3 600,141.1 660,104.9 720,25.6\" fill=\"none\" stroke=\"url(#lineStroke)\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\"></polyline>\n\n        <!-- Data points -->\n        <circle cx=\"60\" cy=\"207.9\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFD700\" stroke-width=\"2\"></circle>\n        <circle cx=\"120\" cy=\"200.5\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFD700\" stroke-width=\"2\"></circle>\n        <circle cx=\"180\" cy=\"173.5\" r=\"5\" fill=\"#FFD700\" stroke=\"var(--bg)\" stroke-width=\"1.5\"></circle>\n        <circle cx=\"240\" cy=\"191.2\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFA500\" stroke-width=\"2\"></circle>\n        <circle cx=\"300\" cy=\"187.2\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFA500\" stroke-width=\"2\"></circle>\n        <circle cx=\"360\" cy=\"187.3\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFA500\" stroke-width=\"2\"></circle>\n        <circle cx=\"420\" cy=\"193.5\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFA500\" stroke-width=\"2\"></circle>\n        <circle cx=\"480\" cy=\"183.6\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFD700\" stroke-width=\"2\"></circle>\n        <circle cx=\"540\" cy=\"137.3\" r=\"5\" fill=\"#FFD700\" stroke=\"var(--bg)\" stroke-width=\"1.5\"></circle>\n        <circle cx=\"600\" cy=\"141.1\" r=\"4\" fill=\"var(--bg)\" stroke=\"#FFD700\" stroke-width=\"2\"></circle>\n        <circle cx=\"660\" cy=\"104.9\" r=\"5\" fill=\"#FFD700\" stroke=\"var(--bg)\" stroke-width=\"1.5\"></circle>\n        <circle cx=\"720\" cy=\"25.6\" r=\"6\" fill=\"#FFD700\" stroke=\"var(--bg)\" stroke-width=\"2\" filter=\"url(#glow)\"></circle>\n\n        <!-- X labels -->\n        <text x=\"60\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">1970</text>\n        <text x=\"180\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">1980</text>\n        <text x=\"300\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">1990</text>\n        <text x=\"420\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">2000</text>\n        <text x=\"540\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">2010</text>\n        <text x=\"660\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">2020</text>\n        <text x=\"720\" y=\"228\" class=\"axis-label\" text-anchor=\"middle\">2025</text>\n\n        <!-- Annotation: 1980 spike -->\n        <line x1=\"180\" y1=\"160\" x2=\"210\" y2=\"145\" stroke=\"#FFD700\" stroke-width=\"1\" stroke-dasharray=\"3,3\" opacity=\"0.5\"></line>\n        <text x=\"212\" y=\"142\" font-family=\"Inter,sans-serif\" font-size=\"9\" fill=\"#FFD700\" opacity=\"0.8\">Oil shock / USSR</text>\n\n        <!-- Annotation: 2025 ATH -->\n        <line x1=\"720\" y1=\"25.6\" x2=\"695\" y2=\"12\" stroke=\"#FFD700\" stroke-width=\"1\" stroke-dasharray=\"3,3\" opacity=\"0.7\"></line>\n        <text x=\"620\" y=\"10\" font-family=\"Inter,sans-serif\" font-size=\"9\" fill=\"#FFD700\" opacity=\"0.9\">ATH ~$3,100 (2025)</text>\n      </svg>",
