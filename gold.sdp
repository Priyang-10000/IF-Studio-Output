                        "id": "tag200",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 740 220\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"hb1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#FFD700\"></stop><stop offset=\"100%\" stop-color=\"#FFA500\"></stop>\n          </linearGradient>\n          <linearGradient id=\"hb2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#FFA500\"></stop><stop offset=\"100%\" stop-color=\"#B8860B\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Labels + bars -->\n        <!-- Electronics: 73% -->\n        <text x=\"160\" y=\"32\" class=\"bar-label\" text-anchor=\"end\">Electronics &amp; Semiconductors</text>\n        <rect x=\"170\" y=\"20\" width=\"413\" height=\"16\" rx=\"4\" fill=\"url(#hb1)\" opacity=\"0.9\"></rect>\n        <text x=\"592\" y=\"32\" class=\"bar-value\" font-size=\"12\">73%</text>\n\n        <!-- Dentistry: 8% -->\n        <text x=\"160\" y=\"72\" class=\"bar-label\" text-anchor=\"end\">Dental Applications</text>\n        <rect x=\"170\" y=\"60\" width=\"45\" height=\"16\" rx=\"4\" fill=\"url(#hb2)\" opacity=\"0.85\"></rect>\n        <text x=\"222\" y=\"72\" class=\"bar-value\" font-size=\"12\">8%</text>\n\n        <!-- Aerospace: 7% -->\n        <text x=\"160\" y=\"112\" class=\"bar-label\" text-anchor=\"end\">Aerospace &amp; Defence</text>\n        <rect x=\"170\" y=\"100\" width=\"40\" height=\"16\" rx=\"4\" fill=\"url(#hb1)\" opacity=\"0.75\"></rect>\n        <text x=\"218\" y=\"112\" class=\"bar-value\" font-size=\"12\">7%</text>\n\n        <!-- Medical: 7% -->\n        <text x=\"160\" y=\"152\" class=\"bar-label\" text-anchor=\"end\">Medical Devices</text>\n        <rect x=\"170\" y=\"140\" width=\"40\" height=\"16\" rx=\"4\" fill=\"url(#hb2)\" opacity=\"0.7\"></rect>\n        <text x=\"218\" y=\"152\" class=\"bar-value\" font-size=\"12\">7%</text>\n\n        <!-- Other: 5% -->\n        <text x=\"160\" y=\"192\" class=\"bar-label\" text-anchor=\"end\">Other Industrial</text>\n        <rect x=\"170\" y=\"180\" width=\"28\" height=\"16\" rx=\"4\" fill=\"url(#hb1)\" opacity=\"0.6\"></rect>\n        <text x=\"206\" y=\"192\" class=\"bar-value\" font-size=\"12\">5%</text>\n\n        <!-- decorative separator line -->\n        <line x1=\"170\" y1=\"20\" x2=\"170\" y2=\"196\" stroke=\"rgba(255,215,0,0.2)\" stroke-width=\"1\"></line>\n\n        <!-- Note -->\n        <text x=\"600\" y=\"200\" class=\"axis-label\" text-anchor=\"middle\" font-size=\"9\">*100% = ~330t tech demand</text>\n      </svg>",
