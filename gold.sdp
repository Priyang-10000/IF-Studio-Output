                                "svgText": "<svg width=\"160\" height=\"160\" viewBox=\"0 0 160 160\" style=\"flex-shrink:0;\">\n            <defs>\n              <linearGradient id=\"d1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#FFD700\"></stop><stop offset=\"100%\" stop-color=\"#FFA500\"></stop>\n              </linearGradient>\n              <linearGradient id=\"d2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#7ecfff\"></stop><stop offset=\"100%\" stop-color=\"#3a90d4\"></stop>\n              </linearGradient>\n              <linearGradient id=\"d3\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#a78bfa\"></stop><stop offset=\"100%\" stop-color=\"#6d28d9\"></stop>\n              </linearGradient>\n              <linearGradient id=\"d4\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#34d399\"></stop><stop offset=\"100%\" stop-color=\"#059669\"></stop>\n              </linearGradient>\n              <linearGradient id=\"d5\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#fb923c\"></stop><stop offset=\"100%\" stop-color=\"#ea580c\"></stop>\n              </linearGradient>\n            </defs>\n            <!-- Donut slices: total 4448t 2023 approx -->\n            <!-- Jewellery 49%: 176.4deg from -90 -->\n            <!-- Central circle -->\n            <circle cx=\"80\" cy=\"80\" r=\"50\" fill=\"var(--bg3)\"></circle>\n            <!-- Slices using stroke-dasharray on circle r=55, circumference=345.4 -->\n            <!-- Jewellery 49% = 169.2 -->\n            <circle cx=\"80\" cy=\"80\" r=\"55\" fill=\"none\" stroke=\"url(#d1)\" stroke-width=\"22\" stroke-dasharray=\"169.2 176.2\" stroke-dashoffset=\"0\" transform=\"rotate(-90 80 80)\"></circle>\n            <!-- Investment 21% = 72.5 -->\n            <circle cx=\"80\" cy=\"80\" r=\"55\" fill=\"none\" stroke=\"url(#d2)\" stroke-width=\"22\" stroke-dasharray=\"72.5 272.9\" stroke-dashoffset=\"-169.2\" transform=\"rotate(-90 80 80)\"></circle>\n            <!-- Central Banks 23% = 79.4 -->\n            <circle cx=\"80\" cy=\"80\" r=\"55\" fill=\"none\" stroke=\"url(#d3)\" stroke-width=\"22\" stroke-dasharray=\"79.4 266\" stroke-dashoffset=\"-241.7\" transform=\"rotate(-90 80 80)\"></circle>\n            <!-- Technology 7% = 24.2 -->\n            <circle cx=\"80\" cy=\"80\" r=\"55\" fill=\"none\" stroke=\"url(#d4)\" stroke-width=\"22\" stroke-dasharray=\"24.2 321.2\" stroke-dashoffset=\"-321.1\" transform=\"rotate(-90 80 80)\"></circle>\n\n            <!-- Inner label -->\n            <text x=\"80\" y=\"76\" text-anchor=\"middle\" font-family=\"Orbitron,sans-serif\" font-size=\"15\" font-weight=\"900\" fill=\"#FFD700\">4,448</text>\n            <text x=\"80\" y=\"91\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\" font-size=\"9\" fill=\"#8892a4\">tonnes 2023</text>\n          </svg>",
