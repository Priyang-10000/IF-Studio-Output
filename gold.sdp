                        "id": "tag40",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 740 280\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"barGrad1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#FFD700\"></stop>\n            <stop offset=\"100%\" stop-color=\"#B8860B\"></stop>\n          </linearGradient>\n          <linearGradient id=\"barGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#FFA500\"></stop>\n            <stop offset=\"100%\" stop-color=\"#7a5500\"></stop>\n          </linearGradient>\n          <filter id=\"glow\">\n            <feGaussianBlur stdDeviation=\"2\" result=\"coloredBlur\"></feGaussianBlur>\n            <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n          </filter>\n        </defs>\n\n        <!-- Grid lines -->\n        <line x1=\"60\" y1=\"20\" x2=\"60\" y2=\"220\" class=\"axis-line\"></line>\n        <line x1=\"60\" y1=\"220\" x2=\"720\" y2=\"220\" class=\"axis-line\"></line>\n        <line x1=\"60\" y1=\"170\" x2=\"720\" y2=\"170\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"120\" x2=\"720\" y2=\"120\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"70\" x2=\"720\" y2=\"70\" class=\"grid-line\"></line>\n        <line x1=\"60\" y1=\"20\" x2=\"720\" y2=\"20\" class=\"grid-line\"></line>\n\n        <!-- Y axis labels -->\n        <text x=\"50\" y=\"224\" class=\"axis-label\" text-anchor=\"end\">0</text>\n        <text x=\"50\" y=\"174\" class=\"axis-label\" text-anchor=\"end\">100</text>\n        <text x=\"50\" y=\"124\" class=\"axis-label\" text-anchor=\"end\">200</text>\n        <text x=\"50\" y=\"74\" class=\"axis-label\" text-anchor=\"end\">300</text>\n        <text x=\"50\" y=\"24\" class=\"axis-label\" text-anchor=\"end\">400</text>\n\n        <!-- Bars: scale 200px = 400t, so 1t = 0.5px -->\n        <!-- China: 375t → 187.5px -->\n        <rect x=\"80\" y=\"32.5\" width=\"66\" height=\"187.5\" fill=\"url(#barGrad1)\" rx=\"4\" filter=\"url(#glow)\" opacity=\"0.95\"></rect>\n        <text x=\"113\" y=\"26\" class=\"bar-value\" text-anchor=\"middle\">375t</text>\n        <text x=\"113\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">China</text>\n\n        <!-- Russia: 310t → 155px -->\n        <rect x=\"165\" y=\"65\" width=\"66\" height=\"155\" fill=\"url(#barGrad2)\" rx=\"4\" opacity=\"0.9\"></rect>\n        <text x=\"198\" y=\"59\" class=\"bar-value\" text-anchor=\"middle\">310t</text>\n        <text x=\"198\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">Russia</text>\n\n        <!-- Australia: 295t → 147.5px -->\n        <rect x=\"250\" y=\"72.5\" width=\"66\" height=\"147.5\" fill=\"url(#barGrad1)\" rx=\"4\" opacity=\"0.85\"></rect>\n        <text x=\"283\" y=\"66\" class=\"bar-value\" text-anchor=\"middle\">295t</text>\n        <text x=\"283\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">Australia</text>\n\n        <!-- Canada: 200t → 100px -->\n        <rect x=\"335\" y=\"120\" width=\"66\" height=\"100\" fill=\"url(#barGrad2)\" rx=\"4\" opacity=\"0.8\"></rect>\n        <text x=\"368\" y=\"114\" class=\"bar-value\" text-anchor=\"middle\">200t</text>\n        <text x=\"368\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">Canada</text>\n\n        <!-- USA: 170t → 85px -->\n        <rect x=\"420\" y=\"135\" width=\"66\" height=\"85\" fill=\"url(#barGrad1)\" rx=\"4\" opacity=\"0.75\"></rect>\n        <text x=\"453\" y=\"129\" class=\"bar-value\" text-anchor=\"middle\">170t</text>\n        <text x=\"453\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">USA</text>\n\n        <!-- Ghana: 130t → 65px -->\n        <rect x=\"505\" y=\"155\" width=\"66\" height=\"65\" fill=\"url(#barGrad2)\" rx=\"4\" opacity=\"0.7\"></rect>\n        <text x=\"538\" y=\"149\" class=\"bar-value\" text-anchor=\"middle\">130t</text>\n        <text x=\"538\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">Ghana</text>\n\n        <!-- Indonesia: 110t → 55px -->\n        <rect x=\"590\" y=\"165\" width=\"66\" height=\"55\" fill=\"url(#barGrad1)\" rx=\"4\" opacity=\"0.65\"></rect>\n        <text x=\"623\" y=\"159\" class=\"bar-value\" text-anchor=\"middle\">110t</text>\n        <text x=\"623\" y=\"240\" class=\"bar-label\" text-anchor=\"middle\">Indonesia</text>\n\n        <!-- Y-axis title -->\n        <text x=\"15\" y=\"130\" class=\"axis-label\" text-anchor=\"middle\" transform=\"rotate(-90,15,130)\">Metric Tonnes / Year</text>\n      </svg>",
