                            "svgText": "<svg width=\"100%\" height=\"70\" viewBox=\"0 0 320 70\">\n          <!-- Timeline line -->\n          <line x1=\"20\" y1=\"35\" x2=\"300\" y2=\"35\" stroke=\"#1a2d4a\" stroke-width=\"2\"></line>\n          <!-- Milestones -->\n          <circle cx=\"20\" cy=\"35\" r=\"6\" fill=\"#4fd1ff\"></circle>\n          <circle cx=\"100\" cy=\"35\" r=\"6\" fill=\"#4fd1ff\" opacity=\"0.8\"></circle>\n          <circle cx=\"180\" cy=\"35\" r=\"6\" fill=\"#a78bfa\" opacity=\"0.8\"></circle>\n          <circle cx=\"260\" cy=\"35\" r=\"6\" fill=\"#34d399\" opacity=\"0.8\"></circle>\n          <circle cx=\"300\" cy=\"35\" r=\"6\" fill=\"#fb923c\"></circle>\n          <!-- Labels top -->\n          <text x=\"20\" y=\"20\" font-size=\"10\" fill=\"#4fd1ff\" text-anchor=\"middle\">Day 1</text>\n          <text x=\"100\" y=\"20\" font-size=\"10\" fill=\"#4fd1ff\" text-anchor=\"middle\">Day 5</text>\n          <text x=\"180\" y=\"20\" font-size=\"10\" fill=\"#a78bfa\" text-anchor=\"middle\">Day 14</text>\n          <text x=\"260\" y=\"20\" font-size=\"10\" fill=\"#34d399\" text-anchor=\"middle\">Day 21</text>\n          <text x=\"300\" y=\"20\" font-size=\"10\" fill=\"#fb923c\" text-anchor=\"middle\">Day 28</text>\n          <!-- Labels bottom -->\n          <text x=\"20\" y=\"55\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">Seed</text>\n          <text x=\"100\" y=\"55\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">0.1ct</text>\n          <text x=\"180\" y=\"55\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">0.5ct</text>\n          <text x=\"260\" y=\"55\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">0.9ct</text>\n          <text x=\"300\" y=\"55\" font-size=\"9\" fill=\"#fb923c\" text-anchor=\"middle\">1.0ct</text>\n          <!-- Progress fill -->\n          <line x1=\"20\" y1=\"35\" x2=\"300\" y2=\"35\" stroke=\"url(#timeGrad)\" stroke-width=\"3\"></line>\n          <defs>\n            <linearGradient id=\"timeGrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#4fd1ff\"></stop>\n              <stop offset=\"100%\" stop-color=\"#fb923c\"></stop>\n            </linearGradient>\n          </defs>\n        </svg>",
