                                "id": "tag157",
                                "dataset": "",
                                "field": "",
                                "svgText": "<svg width=\"140\" height=\"140\" viewBox=\"0 0 140 140\">\n            <defs>\n              <filter id=\"glow\">\n                <feGaussianBlur stdDeviation=\"2\" result=\"coloredBlur\"></feGaussianBlur>\n                <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n              </filter>\n            </defs>\n            <!-- Background circle -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"18\"></circle>\n            <!-- USA: 38% = 238.8deg -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#4fd1ff\" stroke-width=\"18\" stroke-dasharray=\"131.5 214.9\" stroke-dashoffset=\"0\" transform=\"rotate(-90,70,70)\" filter=\"url(#glow)\"></circle>\n            <!-- China: 27% = 169.8deg -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#a78bfa\" stroke-width=\"18\" stroke-dasharray=\"93.5 252.9\" stroke-dashoffset=\"-131.5\" transform=\"rotate(-90,70,70)\"></circle>\n            <!-- India: 18% = 113.2deg -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#34d399\" stroke-width=\"18\" stroke-dasharray=\"62.3 284.1\" stroke-dashoffset=\"-225\" transform=\"rotate(-90,70,70)\"></circle>\n            <!-- Europe: 10% = 63deg -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#fb923c\" stroke-width=\"18\" stroke-dasharray=\"34.6 311.8\" stroke-dashoffset=\"-287.3\" transform=\"rotate(-90,70,70)\"></circle>\n            <!-- Rest: 7% -->\n            <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#f472b6\" stroke-width=\"18\" stroke-dasharray=\"24.2 322.2\" stroke-dashoffset=\"-321.9\" transform=\"rotate(-90,70,70)\"></circle>\n            <!-- Center -->\n            <circle cx=\"70\" cy=\"70\" r=\"42\" fill=\"#0e1a2e\"></circle>\n            <text x=\"70\" y=\"65\" font-size=\"18\" fill=\"#4fd1ff\" text-anchor=\"middle\" font-weight=\"800\" font-family=\"Space Grotesk\">38%</text>\n            <text x=\"70\" y=\"79\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">USA lead</text>\n          </svg>",
