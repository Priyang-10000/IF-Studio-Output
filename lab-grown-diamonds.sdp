                            "field": "",
                            "svgText": "<svg width=\"100%\" height=\"200\" viewBox=\"0 0 520 200\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#4fd1ff\" stop-opacity=\"0.35\"></stop>\n              <stop offset=\"100%\" stop-color=\"#4fd1ff\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#a78bfa\" stop-opacity=\"0.25\"></stop>\n              <stop offset=\"100%\" stop-color=\"#a78bfa\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Grid lines -->\n          <line x1=\"0\" y1=\"20\" x2=\"520\" y2=\"20\" stroke=\"#1a2d4a\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"0\" y1=\"60\" x2=\"520\" y2=\"60\" stroke=\"#1a2d4a\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"0\" y1=\"100\" x2=\"520\" y2=\"100\" stroke=\"#1a2d4a\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"0\" y1=\"140\" x2=\"520\" y2=\"140\" stroke=\"#1a2d4a\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"0\" y1=\"180\" x2=\"520\" y2=\"180\" stroke=\"#1a2d4a\" stroke-width=\"1\"></line>\n          <!-- Y labels -->\n          <text x=\"-30\" y=\"24\" font-size=\"9\" fill=\"#6b85a8\">$25B</text>\n          <text x=\"-30\" y=\"64\" font-size=\"9\" fill=\"#6b85a8\">$20B</text>\n          <text x=\"-30\" y=\"104\" font-size=\"9\" fill=\"#6b85a8\">$15B</text>\n          <text x=\"-30\" y=\"144\" font-size=\"9\" fill=\"#6b85a8\">$10B</text>\n          <text x=\"-30\" y=\"184\" font-size=\"9\" fill=\"#6b85a8\">$5B</text>\n          <!-- Area fill: Lab grown market -->\n          <!-- Data: 2019=3.5, 2020=4.2, 2021=5.8, 2022=8.1, 2023=10.5, 2024=12.8, 2025=15.0, 2026=17.0, 2027=18.8, 2028=20.4, 2029=22.0, 2030=24.0 -->\n          <!-- Scale: y = 180 - (val/25)*160 -->\n          <polygon points=\"0,157.6 47,153.6 95,143 142,128.2 189,112 237,96.6 284,84 331,74.4 379,59.4 426,49.6 473,39.2 520,26.4 520,180 0,180\" fill=\"url(#lineGrad)\"></polygon>\n          <polyline points=\"0,157.6 47,153.6 95,143 142,128.2 189,112 237,96.6 284,84 331,74.4 379,59.4 426,49.6 473,39.2 520,26.4\" fill=\"none\" stroke=\"#4fd1ff\" stroke-width=\"2.5\" stroke-linejoin=\"round\"></polyline>\n          <!-- Data points -->\n          <circle cx=\"0\" cy=\"157.6\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"47\" cy=\"153.6\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"95\" cy=\"143\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"142\" cy=\"128.2\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"189\" cy=\"112\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"237\" cy=\"96.6\" r=\"5\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <circle cx=\"284\" cy=\"84\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\" opacity=\"0.6\"></circle>\n          <circle cx=\"331\" cy=\"74.4\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\" opacity=\"0.6\"></circle>\n          <circle cx=\"379\" cy=\"59.4\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\" opacity=\"0.6\"></circle>\n          <circle cx=\"426\" cy=\"49.6\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\" opacity=\"0.6\"></circle>\n          <circle cx=\"473\" cy=\"39.2\" r=\"4\" fill=\"#4fd1ff\" stroke=\"#050a14\" stroke-width=\"2\" opacity=\"0.6\"></circle>\n          <circle cx=\"520\" cy=\"26.4\" r=\"5\" fill=\"#a78bfa\" stroke=\"#050a14\" stroke-width=\"2\"></circle>\n          <!-- Labels -->\n          <text x=\"0\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2019</text>\n          <text x=\"95\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2021</text>\n          <text x=\"189\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2023</text>\n          <text x=\"284\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2025</text>\n          <text x=\"379\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2027</text>\n          <text x=\"473\" y=\"175\" font-size=\"9\" fill=\"#6b85a8\" text-anchor=\"middle\">2029</text>\n          <text x=\"520\" y=\"175\" font-size=\"9\" fill=\"#a78bfa\" text-anchor=\"middle\">2030</text>\n          <!-- Projection marker -->\n          <line x1=\"237\" y1=\"10\" x2=\"237\" y2=\"180\" stroke=\"#fb923c\" stroke-width=\"1\" stroke-dasharray=\"3,3\" opacity=\"0.5\"></line>\n          <text x=\"245\" y=\"18\" font-size=\"9\" fill=\"#fb923c\">Projected →</text>\n          <!-- Callout -->\n          <rect x=\"195\" y=\"85\" width=\"74\" height=\"22\" rx=\"5\" fill=\"rgba(79,209,255,0.12)\" stroke=\"rgba(79,209,255,0.3)\" stroke-width=\"1\"></rect>\n          <text x=\"232\" y=\"100\" font-size=\"10\" fill=\"#4fd1ff\" text-anchor=\"middle\" font-weight=\"700\">$10.5B (2023)</text>\n        </svg>",
