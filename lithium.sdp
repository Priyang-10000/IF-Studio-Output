                      {
                        "type": "svg",
                        "id": "tag165",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg viewBox=\"0 0 540 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"barForecast\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#00d4ff\"></stop>\n            <stop offset=\"100%\" stop-color=\"#0040aa\"></stop>\n          </linearGradient>\n          <linearGradient id=\"barForecast2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#7c3aed\" stop-opacity=\"0.9\"></stop>\n            <stop offset=\"100%\" stop-color=\"#4c1d95\"></stop>\n          </linearGradient>\n        </defs>\n        <!-- Y grid -->\n        <line x1=\"50\" y1=\"10\" x2=\"50\" y2=\"185\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"185\" x2=\"530\" y2=\"185\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"140\" x2=\"530\" y2=\"140\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"3,3\"></line>\n        <line x1=\"50\" y1=\"95\" x2=\"530\" y2=\"95\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"3,3\"></line>\n        <line x1=\"50\" y1=\"48\" x2=\"530\" y2=\"48\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"3,3\"></line>\n        <!-- Y labels: scale 0-800K, 185→0, 140→200K, 95→400K, 48→600K, 10→800K -->\n        <text x=\"44\" y=\"189\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">0</text>\n        <text x=\"44\" y=\"144\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">200</text>\n        <text x=\"44\" y=\"99\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">400</text>\n        <text x=\"44\" y=\"52\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">600</text>\n        <!-- data: 2020:65K, 2021:100K, 2022:140K, 2023:180K, 2025:260K, 2027:400K, 2030:600K -->\n        <!-- scale: 800K maps to 175px, 1K=0.21875px, y=185-val*0.21875 -->\n        <!-- bars x positions: 65,125,185,245,305,370,440,510 -->\n        <!-- 2020:65K→170.7, 2021:100K→162.9, 2022:140K→154.4, 2023:180K→145.6, 2025:260K→128.1, 2027:400K→97.5, 2030:600K→53.9 -->\n        <rect x=\"60\" y=\"170.7\" width=\"28\" height=\"14.3\" rx=\"3\" fill=\"url(#barForecast)\"></rect>\n        <rect x=\"120\" y=\"162.9\" width=\"28\" height=\"22.1\" rx=\"3\" fill=\"url(#barForecast)\"></rect>\n        <rect x=\"180\" y=\"154.4\" width=\"28\" height=\"30.6\" rx=\"3\" fill=\"url(#barForecast)\"></rect>\n        <rect x=\"240\" y=\"145.6\" width=\"28\" height=\"39.4\" rx=\"3\" fill=\"url(#barForecast)\"></rect>\n        <rect x=\"300\" y=\"128.1\" width=\"28\" height=\"56.9\" rx=\"3\" fill=\"url(#barForecast2)\" opacity=\"0.85\"></rect>\n        <rect x=\"360\" y=\"97.5\" width=\"28\" height=\"87.5\" rx=\"3\" fill=\"url(#barForecast2)\" opacity=\"0.85\"></rect>\n        <rect x=\"430\" y=\"53.9\" width=\"28\" height=\"131.1\" rx=\"3\" fill=\"url(#barForecast2)\" opacity=\"0.85\"></rect>\n        <!-- X labels -->\n        <text x=\"74\" y=\"200\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2020</text>\n        <text x=\"134\" y=\"200\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2021</text>\n        <text x=\"194\" y=\"200\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2022</text>\n        <text x=\"254\" y=\"200\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2023</text>\n        <text x=\"314\" y=\"200\" font-size=\"9\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2025</text>\n        <text x=\"374\" y=\"200\" font-size=\"9\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2027</text>\n        <text x=\"444\" y=\"200\" font-size=\"9\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">2030</text>\n        <!-- Value annotations -->\n        <text x=\"74\" y=\"167\" font-size=\"8\" fill=\"#00d4ff\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">65</text>\n        <text x=\"134\" y=\"159\" font-size=\"8\" fill=\"#00d4ff\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">100</text>\n        <text x=\"194\" y=\"151\" font-size=\"8\" fill=\"#00d4ff\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">140</text>\n        <text x=\"254\" y=\"142\" font-size=\"8\" fill=\"#00d4ff\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">180</text>\n        <text x=\"314\" y=\"124\" font-size=\"8\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">260</text>\n        <text x=\"374\" y=\"93\" font-size=\"8\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">400</text>\n        <text x=\"444\" y=\"49\" font-size=\"8\" fill=\"#a78bfa\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">600</text>\n        <!-- Legend -->\n        <rect x=\"455\" y=\"12\" width=\"10\" height=\"10\" rx=\"2\" fill=\"url(#barForecast)\"></rect>\n        <text x=\"470\" y=\"21\" font-size=\"8\" fill=\"#00d4ff\" font-family=\"Inter,sans-serif\">Actual</text>\n        <rect x=\"455\" y=\"27\" width=\"10\" height=\"10\" rx=\"2\" fill=\"url(#barForecast2)\"></rect>\n        <text x=\"470\" y=\"36\" font-size=\"8\" fill=\"#a78bfa\" font-family=\"Inter,sans-serif\">Forecast</text>\n        <!-- Thousand label -->\n        <text x=\"50\" y=\"10\" font-size=\"8\" fill=\"#6b8ba4\" font-family=\"Inter,sans-serif\">KT</text>\n      </svg>",
