                            "id": "tag135",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 200 200\" width=\"170\" height=\"170\">\n          <defs>\n            <filter id=\"ds\">\n              <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"4\" flood-color=\"rgba(0,212,255,0.3)\"></feDropShadow>\n            </filter>\n          </defs>\n          <!-- Donut segments: Bolivia 23%, Argentina 20%, Chile 11%, USA 9%, Australia 8%, Others 29% -->\n          <!-- Circumference = 2π×70 ≈ 439.8 -->\n          <!-- strokeDasharray = pct/100 * 439.8, offset accumulates -->\n          <!-- Bolivia 23%: 101.2, offset 0 -->\n          <!-- Argentina 20%: 87.96, offset 101.2 -->\n          <!-- Chile 11%: 48.38, offset 189.16 -->\n          <!-- USA 9%: 39.58, offset 237.54 -->\n          <!-- Australia 8%: 35.18, offset 277.12 -->\n          <!-- Others 29%: 127.54, offset 312.3 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#0a1525\" stroke-width=\"36\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"34\" stroke-dasharray=\"101.2 338.6\" stroke-dashoffset=\"109.95\" stroke-linecap=\"butt\" filter=\"url(#ds)\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#7c3aed\" stroke-width=\"34\" stroke-dasharray=\"87.96 351.84\" stroke-dashoffset=\"8.75\" stroke-linecap=\"butt\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"34\" stroke-dasharray=\"48.38 391.42\" stroke-dashoffset=\"-79.21\" stroke-linecap=\"butt\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"34\" stroke-dasharray=\"39.58 400.22\" stroke-dashoffset=\"-127.59\" stroke-linecap=\"butt\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#ef4444\" stroke-width=\"34\" stroke-dasharray=\"35.18 404.62\" stroke-dashoffset=\"-167.17\" stroke-linecap=\"butt\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#475569\" stroke-width=\"34\" stroke-dasharray=\"127.54 312.26\" stroke-dashoffset=\"-202.35\" stroke-linecap=\"butt\"></circle>\n          <!-- Center text -->\n          <text x=\"100\" y=\"95\" text-anchor=\"middle\" font-family=\"Orbitron,monospace\" font-size=\"16\" font-weight=\"900\" fill=\"white\">98</text>\n          <text x=\"100\" y=\"110\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\" font-size=\"9\" fill=\"#6b8ba4\">MT TOTAL</text>\n        </svg>",
