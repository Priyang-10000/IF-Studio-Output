                                "field": "",
                                "svgText": "<svg viewBox=\"0 0 240 300\" width=\"200\" height=\"260\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <radialGradient id=\"salarGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n                <stop offset=\"0%\" stop-color=\"rgba(0,212,255,0.5)\"></stop>\n                <stop offset=\"100%\" stop-color=\"rgba(0,80,200,0.15)\"></stop>\n              </radialGradient>\n            </defs>\n            <!-- Simple South America silhouette / Atacama region -->\n            <path d=\"M80,10 Q130,8 160,25 Q185,45 190,80 Q195,110 180,140 Q165,170 170,200 Q175,230 155,265 Q130,285 110,270 Q90,260 75,240 Q55,215 60,185 Q65,155 50,130 Q35,105 40,75 Q45,45 65,25 Z\" fill=\"rgba(255,255,255,0.04)\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"1.5\"></path>\n            <!-- Chile strip -->\n            <path d=\"M75,80 Q70,100 68,130 Q65,160 60,190 Q68,215 78,235 Q88,255 90,265 Q100,270 105,260 Q98,235 95,210 Q88,175 90,150 Q92,120 95,100 Z\" fill=\"rgba(16,185,129,0.2)\" stroke=\"rgba(16,185,129,0.4)\" stroke-width=\"1\"></path>\n            <!-- Bolivia highlight -->\n            <path d=\"M100,80 Q130,75 155,90 Q165,110 155,130 Q140,140 115,135 Q95,130 92,115 Q90,100 100,80 Z\" fill=\"rgba(59,130,246,0.25)\" stroke=\"rgba(59,130,246,0.5)\" stroke-width=\"1\"></path>\n            <!-- Argentina upper region -->\n            <path d=\"M92,115 Q115,135 155,130 Q168,145 165,170 Q150,175 130,165 Q110,155 95,150 Q88,135 92,115 Z\" fill=\"rgba(124,58,237,0.2)\" stroke=\"rgba(124,58,237,0.4)\" stroke-width=\"1\"></path>\n            <!-- Triangle outline -->\n            <polygon points=\"82,220 147,85 165,165\" fill=\"none\" stroke=\"rgba(0,212,255,0.6)\" stroke-width=\"1.5\" stroke-dasharray=\"5,3\"></polygon>\n            <!-- Salar dots -->\n            <circle cx=\"90\" cy=\"170\" r=\"8\" fill=\"url(#salarGrad)\" stroke=\"rgba(0,212,255,0.8)\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"135\" cy=\"100\" r=\"9\" fill=\"url(#salarGrad)\" stroke=\"rgba(59,130,246,0.8)\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"155\" cy=\"145\" r=\"7\" fill=\"url(#salarGrad)\" stroke=\"rgba(124,58,237,0.8)\" stroke-width=\"1.5\"></circle>\n            <!-- Labels -->\n            <text x=\"72\" y=\"186\" font-size=\"8\" fill=\"#10b981\" font-family=\"Inter,sans-serif\" font-weight=\"700\">Chile</text>\n            <text x=\"118\" y=\"97\" font-size=\"8\" fill=\"#3b82f6\" font-family=\"Inter,sans-serif\" font-weight=\"700\">Bolivia</text>\n            <text x=\"140\" y=\"158\" font-size=\"8\" fill=\"#a78bfa\" font-family=\"Inter,sans-serif\" font-weight=\"700\">Argentina</text>\n            <!-- Li symbol pulsing -->\n            <circle cx=\"126\" cy=\"138\" r=\"12\" fill=\"rgba(0,212,255,0.1)\" stroke=\"rgba(0,212,255,0.4)\" stroke-width=\"1\"></circle>\n            <text x=\"126\" y=\"143\" text-anchor=\"middle\" font-size=\"10\" fill=\"#00d4ff\" font-family=\"Orbitron,monospace\" font-weight=\"900\">Li</text>\n            <!-- Title -->\n            <text x=\"120\" y=\"295\" text-anchor=\"middle\" font-size=\"9\" fill=\"#6b8ba4\" font-family=\"Inter,sans-serif\">Lithium Triangle</text>\n          </svg>",
