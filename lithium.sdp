                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 600 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.4\"></stop>\n              <stop offset=\"100%\" stop-color=\"#00d4ff\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#7c3aed\"></stop>\n              <stop offset=\"50%\" stop-color=\"#00d4ff\"></stop>\n              <stop offset=\"100%\" stop-color=\"#10b981\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Grid lines -->\n          <line x1=\"40\" y1=\"10\" x2=\"40\" y2=\"185\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"></line>\n          <line x1=\"40\" y1=\"185\" x2=\"590\" y2=\"185\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"></line>\n          <line x1=\"40\" y1=\"140\" x2=\"590\" y2=\"140\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"40\" y1=\"95\" x2=\"590\" y2=\"95\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"40\" y1=\"50\" x2=\"590\" y2=\"50\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n          <!-- Y-axis labels -->\n          <text x=\"32\" y=\"189\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">0</text>\n          <text x=\"32\" y=\"144\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">20K</text>\n          <text x=\"32\" y=\"99\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">40K</text>\n          <text x=\"32\" y=\"54\" font-size=\"9\" fill=\"#6b8ba4\" text-anchor=\"end\" font-family=\"Inter,sans-serif\">60K</text>\n          <!-- Area fill (approx data: 2018:10K, 2019:9K, 2020:7K, 2021:17K, 2022:70K, 2023:25K, 2024:14K) -->\n          <!-- Scale: 70K = 175px height, so 1K = 2.5px, y = 185 - val*2.5 -->\n          <!-- 10K→160, 9K→162.5, 7K→167.5, 17K→142.5, 70K→10, 25K→122.5, 14K→150 -->\n          <!-- x positions evenly: 40,130,220,310,400,490,580 -->\n          <path d=\"M40,160 L130,162.5 L220,167.5 L310,142.5 L400,10 L490,122.5 L580,150 L580,185 L40,185 Z\" fill=\"url(#lineGrad)\" opacity=\"0.7\"></path>\n          <polyline points=\"40,160 130,162.5 220,167.5 310,142.5 400,10 490,122.5 580,150\" fill=\"none\" stroke=\"url(#lineStroke)\" stroke-width=\"2.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\"></polyline>\n          <!-- Data points -->\n          <circle cx=\"40\" cy=\"160\" r=\"4\" fill=\"#7c3aed\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"130\" cy=\"162.5\" r=\"4\" fill=\"#6d5aed\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"220\" cy=\"167.5\" r=\"4\" fill=\"#0080ff\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"310\" cy=\"142.5\" r=\"4\" fill=\"#00d4ff\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"400\" cy=\"10\" r=\"5\" fill=\"#f59e0b\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"490\" cy=\"122.5\" r=\"4\" fill=\"#10b981\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <circle cx=\"580\" cy=\"150\" r=\"4\" fill=\"#10b981\" stroke=\"#0d1a2e\" stroke-width=\"2\"></circle>\n          <!-- Peak label -->\n          <rect x=\"360\" y=\"0\" width=\"85\" height=\"20\" rx=\"4\" fill=\"rgba(245,158,11,0.2)\" stroke=\"rgba(245,158,11,0.5)\" stroke-width=\"1\"></rect>\n          <text x=\"402\" y=\"13\" font-size=\"9\" fill=\"#f59e0b\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\" font-weight=\"700\">PEAK ~$70K</text>\n          <line x1=\"400\" y1=\"10\" x2=\"400\" y2=\"21\" stroke=\"rgba(245,158,11,0.5)\" stroke-width=\"1\" stroke-dasharray=\"2,2\"></line>\n          <!-- Value labels on last point -->\n          <text x=\"580\" y=\"144\" font-size=\"9\" fill=\"#10b981\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\">$14K</text>\n        </svg>",
