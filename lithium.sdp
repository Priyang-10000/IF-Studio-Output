                  {
                    "type": "container",
                    "id": "tag12",
                    "selfContain": false,
                    "backgroundImage": {},
                    "children": [
                      {
                        "type": "svg",
                        "id": "tag13",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"280\" height=\"280\" viewBox=\"0 0 280 280\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <radialGradient id=\"nucGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#00d4ff\"></stop>\n            <stop offset=\"100%\" stop-color=\"#0060aa\"></stop>\n          </radialGradient>\n          <radialGradient id=\"eGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#c084fc\"></stop>\n            <stop offset=\"100%\" stop-color=\"#7c3aed\"></stop>\n          </radialGradient>\n          <filter id=\"glow\">\n            <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"></feGaussianBlur>\n            <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n          </filter>\n        </defs>\n        <!-- Outer orbit 1 -->\n        <ellipse cx=\"140\" cy=\"140\" rx=\"120\" ry=\"48\" stroke=\"#00d4ff\" stroke-width=\"1\" stroke-opacity=\"0.25\" fill=\"none\"></ellipse>\n        <!-- Outer orbit 2 rotated 60deg -->\n        <ellipse cx=\"140\" cy=\"140\" rx=\"120\" ry=\"48\" stroke=\"#7c3aed\" stroke-width=\"1\" stroke-opacity=\"0.25\" fill=\"none\" transform=\"rotate(60 140 140)\"></ellipse>\n        <!-- Outer orbit 3 rotated 120deg -->\n        <ellipse cx=\"140\" cy=\"140\" rx=\"120\" ry=\"48\" stroke=\"#10b981\" stroke-width=\"1\" stroke-opacity=\"0.25\" fill=\"none\" transform=\"rotate(120 140 140)\"></ellipse>\n        <!-- Inner orbit K shell -->\n        <ellipse cx=\"140\" cy=\"140\" rx=\"60\" ry=\"24\" stroke=\"#00d4ff\" stroke-width=\"1.5\" stroke-opacity=\"0.5\" fill=\"none\"></ellipse>\n        <ellipse cx=\"140\" cy=\"140\" rx=\"60\" ry=\"24\" stroke=\"#00d4ff\" stroke-width=\"1.5\" stroke-opacity=\"0.5\" fill=\"none\" transform=\"rotate(60 140 140)\"></ellipse>\n        <!-- Glow rings -->\n        <circle cx=\"140\" cy=\"140\" r=\"38\" fill=\"rgba(0,212,255,0.06)\"></circle>\n        <circle cx=\"140\" cy=\"140\" r=\"28\" fill=\"rgba(0,212,255,0.08)\"></circle>\n        <!-- Nucleus -->\n        <circle cx=\"140\" cy=\"140\" r=\"22\" fill=\"url(#nucGrad)\" filter=\"url(#glow)\"></circle>\n        <text x=\"140\" y=\"137\" text-anchor=\"middle\" font-family=\"Orbitron,monospace\" font-size=\"12\" font-weight=\"900\" fill=\"white\">Li</text>\n        <text x=\"140\" y=\"150\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\" font-size=\"9\" fill=\"rgba(255,255,255,0.7)\">3</text>\n        <!-- Electrons on orbit 1 -->\n        <circle cx=\"260\" cy=\"140\" r=\"7\" fill=\"url(#eGrad)\" filter=\"url(#glow)\"></circle>\n        <circle cx=\"20\" cy=\"140\" r=\"7\" fill=\"url(#eGrad)\" filter=\"url(#glow)\"></circle>\n        <!-- Electrons on rotated orbit (K shell 2e) -->\n        <circle cx=\"110\" cy=\"118\" r=\"6\" fill=\"#00d4ff\" filter=\"url(#glow)\"></circle>\n        <circle cx=\"170\" cy=\"162\" r=\"6\" fill=\"#00d4ff\" filter=\"url(#glow)\"></circle>\n        <!-- Valence electron on L shell -->\n        <circle cx=\"185\" cy=\"92\" r=\"7\" fill=\"#f59e0b\" filter=\"url(#glow)\" stroke=\"#fbbf24\" stroke-width=\"1.5\"></circle>\n        <!-- Labels -->\n        <text x=\"252\" y=\"132\" font-size=\"9\" fill=\"#a78bfa\" font-family=\"Inter,sans-serif\">e⁻</text>\n        <text x=\"12\" y=\"132\" font-size=\"9\" fill=\"#a78bfa\" font-family=\"Inter,sans-serif\">e⁻</text>\n        <text x=\"192\" y=\"88\" font-size=\"9\" fill=\"#f59e0b\" font-family=\"Inter,sans-serif\">e⁻</text>\n        <!-- Periodic block -->\n        <rect x=\"4\" y=\"220\" width=\"60\" height=\"52\" rx=\"6\" fill=\"rgba(0,212,255,0.08)\" stroke=\"rgba(0,212,255,0.3)\" stroke-width=\"1\"></rect>\n        <text x=\"34\" y=\"239\" text-anchor=\"middle\" font-size=\"8\" fill=\"var(--muted)\" font-family=\"Inter,sans-serif\">ELEMENT</text>\n        <text x=\"34\" y=\"254\" text-anchor=\"middle\" font-size=\"18\" font-weight=\"900\" fill=\"#00d4ff\" font-family=\"Orbitron,monospace\">Li</text>\n        <text x=\"34\" y=\"266\" text-anchor=\"middle\" font-size=\"7\" fill=\"var(--muted)\" font-family=\"Inter,sans-serif\">Lithium</text>\n        <text x=\"34\" y=\"276\" text-anchor=\"middle\" font-size=\"8\" fill=\"#a78bfa\" font-family=\"Inter,sans-serif\">6.941 u</text>\n      </svg>",
