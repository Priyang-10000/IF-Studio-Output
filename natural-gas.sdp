                            "type": "svg",
                            "id": "tag109",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"100%\" height=\"240\" viewBox=\"0 0 1000 240\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.35\"></stop>\n              <stop offset=\"100%\" stop-color=\"#00d4ff\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#a855f7\"></stop>\n              <stop offset=\"50%\" stop-color=\"#00d4ff\"></stop>\n              <stop offset=\"100%\" stop-color=\"#00ff9d\"></stop>\n            </linearGradient>\n            <filter id=\"lineglow\"><feGaussianBlur stdDeviation=\"3\"></feGaussianBlur></filter>\n          </defs>\n          <!-- Grid lines -->\n          <line x1=\"0\" y1=\"0\" x2=\"1000\" y2=\"0\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n          <line x1=\"0\" y1=\"48\" x2=\"1000\" y2=\"48\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n          <line x1=\"0\" y1=\"96\" x2=\"1000\" y2=\"96\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n          <line x1=\"0\" y1=\"144\" x2=\"1000\" y2=\"144\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n          <line x1=\"0\" y1=\"192\" x2=\"1000\" y2=\"192\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n          <!-- Area fill -->\n          <!-- Points mapped: 2000=2400BCM, 2005=2720, 2010=3200, 2015=3550, 2019=3990, 2020=3850, 2021=4000, 2022=3960, 2023=4037 -->\n          <!-- Y range 2200-4200=2000 units over 240px. Scale=(240/2000)=0.12. Y=240 - (val-2200)*0.12 -->\n          <!-- 2400→216.0, 2720→192.0, 3200→156.0, 3550→132.0, 3990→107.2, 3850→117.0, 4000→106.4, 3960→109.2, 4037→104.0 -->\n          <!-- X: 0 to 1000 over 24 years (2000-2023), step=43.5 -->\n          <!-- Points: 2000=0,216 | 2003=130,200 | 2005=217,192 | 2008=348,170 | 2010=435,156 | 2013=565,140 | 2015=652,132 | 2017=739,118 | 2019=826,107 | 2020=870,117 | 2021=913,106 | 2022=956,109 | 2023=1000,104 -->\n          <path d=\"M0,216 C60,210 120,204 130,200 C160,196 200,194 217,192 C270,183 320,174 348,170 C390,163 415,160 435,156 C490,148 530,144 565,140 C600,137 630,134 652,132 C690,127 720,122 739,118 C780,112 810,109 826,107 L870,117 L913,106 L956,109 L1000,104 L1000,240 L0,240 Z\" fill=\"url(#lineGrad)\"></path>\n          <!-- Glow line -->\n          <path d=\"M0,216 C60,210 120,204 130,200 C160,196 200,194 217,192 C270,183 320,174 348,170 C390,163 415,160 435,156 C490,148 530,144 565,140 C600,137 630,134 652,132 C690,127 720,122 739,118 C780,112 810,109 826,107 L870,117 L913,106 L956,109 L1000,104\" fill=\"none\" stroke=\"#00d4ff\" stroke-width=\"6\" opacity=\"0.3\" filter=\"url(#lineglow)\"></path>\n          <!-- Main line -->\n          <path d=\"M0,216 C60,210 120,204 130,200 C160,196 200,194 217,192 C270,183 320,174 348,170 C390,163 415,160 435,156 C490,148 530,144 565,140 C600,137 630,134 652,132 C690,127 720,122 739,118 C780,112 810,109 826,107 L870,117 L913,106 L956,109 L1000,104\" fill=\"none\" stroke=\"url(#lineStroke)\" stroke-width=\"2.5\" stroke-linejoin=\"round\"></path>\n          <!-- Dots at key years -->\n          <circle cx=\"0\" cy=\"216\" r=\"5\" fill=\"#a855f7\" stroke=\"#070d1a\" stroke-width=\"2\"></circle>\n          <circle cx=\"435\" cy=\"156\" r=\"5\" fill=\"#00d4ff\" stroke=\"#070d1a\" stroke-width=\"2\"></circle>\n          <circle cx=\"826\" cy=\"107\" r=\"5\" fill=\"#00ff9d\" stroke=\"#070d1a\" stroke-width=\"2\"></circle>\n          <circle cx=\"870\" cy=\"117\" r=\"5\" fill=\"#ff6b35\" stroke=\"#070d1a\" stroke-width=\"2\"></circle>\n          <circle cx=\"1000\" cy=\"104\" r=\"5\" fill=\"#ffd700\" stroke=\"#070d1a\" stroke-width=\"2\"></circle>\n          <!-- Labels -->\n          <text x=\"0\" y=\"207\" font-family=\"Inter,sans-serif\" font-size=\"10\" fill=\"#a855f7\" text-anchor=\"middle\">2,400</text>\n          <text x=\"435\" y=\"147\" font-family=\"Inter,sans-serif\" font-size=\"10\" fill=\"#00d4ff\" text-anchor=\"middle\">3,200</text>\n          <text x=\"826\" y=\"98\" font-family=\"Inter,sans-serif\" font-size=\"10\" fill=\"#00ff9d\" text-anchor=\"middle\">3,990</text>\n          <text x=\"870\" y=\"130\" font-family=\"Inter,sans-serif\" font-size=\"10\" fill=\"#ff6b35\" text-anchor=\"middle\">COVID</text>\n          <text x=\"1000\" y=\"95\" font-family=\"Inter,sans-serif\" font-size=\"10\" fill=\"#ffd700\" text-anchor=\"middle\">4,037</text>\n        </svg>",
