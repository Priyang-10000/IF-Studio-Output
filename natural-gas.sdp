                      {
                        "type": "svg",
                        "id": "tag10",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"180\" height=\"220\" viewBox=\"0 0 180 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <radialGradient id=\"glowBase\" cx=\"50%\" cy=\"100%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.3\"></stop>\n            <stop offset=\"100%\" stop-color=\"transparent\"></stop>\n          </radialGradient>\n          <linearGradient id=\"flame1\" x1=\"90\" y1=\"200\" x2=\"90\" y2=\"20\" gradientUnits=\"userSpaceOnUse\">\n            <stop offset=\"0%\" stop-color=\"#ff6b35\"></stop>\n            <stop offset=\"40%\" stop-color=\"#ffd700\"></stop>\n            <stop offset=\"80%\" stop-color=\"#fff\"></stop>\n            <stop offset=\"100%\" stop-color=\"rgba(255,255,255,0)\"></stop>\n          </linearGradient>\n          <linearGradient id=\"flame2\" x1=\"90\" y1=\"180\" x2=\"90\" y2=\"60\" gradientUnits=\"userSpaceOnUse\">\n            <stop offset=\"0%\" stop-color=\"#ff6b35\" stop-opacity=\"0.8\"></stop>\n            <stop offset=\"60%\" stop-color=\"#00d4ff\" stop-opacity=\"0.6\"></stop>\n            <stop offset=\"100%\" stop-color=\"rgba(0,212,255,0)\"></stop>\n          </linearGradient>\n          <filter id=\"blur1\">\n            <feGaussianBlur stdDeviation=\"6\"></feGaussianBlur>\n          </filter>\n        </defs>\n        <!-- Glow base -->\n        <ellipse cx=\"90\" cy=\"200\" rx=\"70\" ry=\"18\" fill=\"url(#glowBase)\" filter=\"url(#blur1)\"></ellipse>\n        <!-- Outer flame -->\n        <path d=\"M90 200 C50 180 30 140 45 100 C55 70 40 50 55 30 C60 22 68 18 70 30 C72 42 60 55 70 70 C78 82 90 60 88 40 C86 22 95 10 100 25 C108 45 95 70 105 90 C115 108 140 120 135 150 C130 175 115 185 90 200 Z\" fill=\"url(#flame1)\" opacity=\"0.9\"></path>\n        <!-- Inner flame -->\n        <path d=\"M90 195 C65 178 55 150 65 120 C72 100 62 80 72 65 C76 58 80 58 82 68 C84 78 76 92 84 104 C90 114 96 98 95 82 C94 68 100 58 104 70 C110 88 100 112 108 130 C116 148 128 158 122 178 C116 192 105 196 90 195 Z\" fill=\"url(#flame2)\" opacity=\"0.8\"></path>\n        <!-- Pipe at bottom -->\n        <rect x=\"70\" y=\"198\" width=\"40\" height=\"14\" rx=\"4\" fill=\"#1a3a5c\"></rect>\n        <rect x=\"55\" y=\"208\" width=\"70\" height=\"10\" rx=\"5\" fill=\"#0d2840\"></rect>\n        <!-- Pipe glow -->\n        <ellipse cx=\"90\" cy=\"205\" rx=\"30\" ry=\"5\" fill=\"#ff6b35\" opacity=\"0.3\" filter=\"url(#blur1)\"></ellipse>\n        <!-- Molecules floating -->\n        <circle cx=\"30\" cy=\"80\" r=\"5\" fill=\"none\" stroke=\"#00d4ff\" stroke-width=\"1.5\" opacity=\"0.5\"></circle>\n        <circle cx=\"30\" cy=\"80\" r=\"2\" fill=\"#00d4ff\" opacity=\"0.5\"></circle>\n        <circle cx=\"148\" cy=\"100\" r=\"4\" fill=\"none\" stroke=\"#00ff9d\" stroke-width=\"1.5\" opacity=\"0.4\"></circle>\n        <circle cx=\"148\" cy=\"100\" r=\"1.5\" fill=\"#00ff9d\" opacity=\"0.4\"></circle>\n        <circle cx=\"22\" cy=\"140\" r=\"3\" fill=\"none\" stroke=\"#ffd700\" stroke-width=\"1\" opacity=\"0.4\"></circle>\n        <circle cx=\"155\" cy=\"60\" r=\"3\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1\" opacity=\"0.5\"></circle>\n        <!-- CH4 label -->\n        <text x=\"90\" y=\"145\" text-anchor=\"middle\" font-family=\"Orbitron,sans-serif\" font-size=\"18\" font-weight=\"900\" fill=\"white\" opacity=\"0.15\">CH₄</text>\n      </svg>",
