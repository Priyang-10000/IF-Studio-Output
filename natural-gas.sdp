                        "id": "tag75",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"180\" height=\"180\" viewBox=\"0 0 180 180\">\n        <defs>\n          <filter id=\"glow2\"><feGaussianBlur stdDeviation=\"3\" result=\"blur\"></feGaussianBlur><feMerge><feMergeNode in=\"blur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge></filter>\n        </defs>\n        <!-- Donut segments via stroke-dasharray on circles -->\n        <!-- Total circumference for r=72: 2π×72 ≈ 452.4 -->\n        <!-- CH4: 90% → 407.2 -->\n        <circle cx=\"90\" cy=\"90\" r=\"72\" fill=\"none\" stroke=\"#00d4ff\" stroke-width=\"22\" stroke-dasharray=\"407.2 45.2\" stroke-dashoffset=\"113.1\" filter=\"url(#glow2)\" opacity=\"0.9\"></circle>\n        <!-- Ethane: 5% → 22.6 -->\n        <circle cx=\"90\" cy=\"90\" r=\"72\" fill=\"none\" stroke=\"#00ff9d\" stroke-width=\"22\" stroke-dasharray=\"22.6 429.8\" stroke-dashoffset=\"-294.1\"></circle>\n        <!-- Propane: 2% → 9.0 -->\n        <circle cx=\"90\" cy=\"90\" r=\"72\" fill=\"none\" stroke=\"#ffd700\" stroke-width=\"22\" stroke-dasharray=\"9.0 443.4\" stroke-dashoffset=\"-316.7\"></circle>\n        <!-- Butane: 1% → 4.5 -->\n        <circle cx=\"90\" cy=\"90\" r=\"72\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"22\" stroke-dasharray=\"4.5 447.9\" stroke-dashoffset=\"-325.7\"></circle>\n        <!-- CO2+N2: 2% → 9.0 -->\n        <circle cx=\"90\" cy=\"90\" r=\"72\" fill=\"none\" stroke=\"#a855f7\" stroke-width=\"22\" stroke-dasharray=\"9.0 443.4\" stroke-dashoffset=\"-330.2\"></circle>\n        <!-- Center label -->\n        <text x=\"90\" y=\"85\" text-anchor=\"middle\" font-family=\"Orbitron,sans-serif\" font-size=\"22\" font-weight=\"900\" fill=\"white\">CH₄</text>\n        <text x=\"90\" y=\"104\" text-anchor=\"middle\" font-family=\"Inter,sans-serif\" font-size=\"11\" fill=\"#6a8aaa\">Methane</text>\n      </svg>",
