                            "id": "tag210",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"160\" height=\"160\" viewBox=\"0 0 160 160\">\n          <!-- Fuelwood: 53% → 191.88deg stroke -->\n          <!-- Industrial Roundwood: 47% -->\n          <!-- Of Industrial: Construction 35%, Paper/Pulp 28%, Panels 18%, Furniture 12%, Other 7% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"var(--surface3)\" stroke-width=\"22\"></circle>\n          <!-- Segment 1: Fuelwood 53% = 188.28 of 376.56 circumference (r=60, C=377) -->\n          <!-- Fuelwood: 53% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"22\" stroke-dasharray=\"199.6 377\" stroke-dashoffset=\"94.25\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Industrial Sawnwood: 18% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#22d3ee\" stroke-width=\"22\" stroke-dasharray=\"67.86 377\" stroke-dashoffset=\"-105.35\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Paper/Pulp: 15% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"22\" stroke-dasharray=\"56.55 377\" stroke-dashoffset=\"-173.21\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Wood Panels: 8% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#a78bfa\" stroke-width=\"22\" stroke-dasharray=\"30.16 377\" stroke-dashoffset=\"-229.76\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Other/Furniture: 6% -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#f87171\" stroke-width=\"22\" stroke-dasharray=\"22.62 377\" stroke-dashoffset=\"-259.92\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Center hole -->\n          <circle cx=\"80\" cy=\"80\" r=\"49\" fill=\"var(--surface)\"></circle>\n        </svg>",
                            "record": 0,
                            "unique": true,
                            "filtered": true,
                            "isFilter": false,
