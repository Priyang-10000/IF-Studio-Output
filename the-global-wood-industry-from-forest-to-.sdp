                        "svgText": "<svg width=\"100%\" height=\"260\" viewBox=\"0 0 720 260\" preserveAspectRatio=\"xMidYMid meet\">\n        <!-- Grid lines -->\n        <line x1=\"0\" y1=\"20\" x2=\"720\" y2=\"20\" stroke=\"rgba(42,51,80,0.5)\" stroke-width=\"1\"></line>\n        <line x1=\"0\" y1=\"70\" x2=\"720\" y2=\"70\" stroke=\"rgba(42,51,80,0.4)\" stroke-width=\"1\"></line>\n        <line x1=\"0\" y1=\"120\" x2=\"720\" y2=\"120\" stroke=\"rgba(42,51,80,0.4)\" stroke-width=\"1\"></line>\n        <line x1=\"0\" y1=\"170\" x2=\"720\" y2=\"170\" stroke=\"rgba(42,51,80,0.4)\" stroke-width=\"1\"></line>\n        <line x1=\"0\" y1=\"220\" x2=\"720\" y2=\"220\" stroke=\"rgba(42,51,80,0.5)\" stroke-width=\"1\"></line>\n\n        <!-- X grid lines (vertical) -->\n        <line x1=\"80\" y1=\"20\" x2=\"80\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"160\" y1=\"20\" x2=\"160\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"240\" y1=\"20\" x2=\"240\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"320\" y1=\"20\" x2=\"320\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"400\" y1=\"20\" x2=\"400\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"480\" y1=\"20\" x2=\"480\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"560\" y1=\"20\" x2=\"560\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"640\" y1=\"20\" x2=\"640\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"720\" y1=\"20\" x2=\"720\" y2=\"220\" stroke=\"rgba(42,51,80,0.3)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n\n        <!-- Data points mapped: \n             Y axis: 350=220, 450=170, 550=120, 650=70, 750=20\n             So: value → y = 220 - (value-350)/4\n             2015: 415 → y=204.6\n             2016: 432 → y=202\n             2017: 458 → y=197.5\n             2018: 485 → y=191.25 (wait let me recalculate)\n             Range: 350-750 = 400 units over 200px height (220-20=200)\n             scale = 200/400 = 0.5 px per unit\n             y = 220 - (value - 350) * 0.5\n             2015: 415 → 220 - (415-350)*0.5 = 220-32.5 = 187.5\n             2016: 432 → 220 - (432-350)*0.5 = 220-41 = 179\n             2017: 458 → 220 - (458-350)*0.5 = 220-54 = 166\n             2018: 487 → 220 - (487-350)*0.5 = 220-68.5 = 151.5\n             2019: 505 → 220 - (505-350)*0.5 = 220-77.5 = 142.5\n             2020: 478 → 220 - (478-350)*0.5 = 220-64 = 156 (COVID dip)\n             2021: 555 → 220 - (555-350)*0.5 = 220-102.5 = 117.5\n             2022: 598 → 220 - (598-350)*0.5 = 220-124 = 96\n             2023: 637 → 220 - (637-350)*0.5 = 220-143.5 = 76.5\n             2024E: 668 → 220 - (668-350)*0.5 = 220-159 = 61\n             X positions: evenly from 40 to 720, 9 years = step 85\n             x: 40, 125, 210, 295, 380, 465, 550, 635, 720\n             Wait, 2015-2024 = 10 points, step = (720-0)/9 = 80 \n             x: 0, 80, 160, 240, 320, 400, 480, 560, 640, 720\n        -->\n\n        <!-- Gradient fill area -->\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#f59e0b\" stop-opacity=\"0.3\"></stop>\n            <stop offset=\"100%\" stop-color=\"#f59e0b\" stop-opacity=\"0.02\"></stop>\n          </linearGradient>\n          <linearGradient id=\"lineGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#22d3ee\" stop-opacity=\"0.25\"></stop>\n            <stop offset=\"100%\" stop-color=\"#22d3ee\" stop-opacity=\"0.02\"></stop>\n          </linearGradient>\n          <!-- Projection dashed after 2023 -->\n        </defs>\n\n        <!-- Fill area (main market) -->\n        <path d=\"M0,187.5 L80,179 L160,166 L240,151.5 L320,142.5 L400,156 L480,117.5 L560,96 L640,76.5 L720,61 L720,220 L0,220 Z\" fill=\"url(#lineGrad)\"></path>\n\n        <!-- Furniture sub-market line: 2015:180 2016:192 2017:205 2018:220 2019:231 2020:218 2021:248 2022:264 2023:280 2024E:298\n             y = 220 - (v-350)*0.5 ... wait furniture is smaller, let me use different values \n             Actually let me place furniture on same axis: 2015:180 is below 350, so let me just offset furniture\n             Let me use a secondary axis conceptually but draw relative:\n             Scale furniture to same range: max ~300, min ~150\n             Use same formula: y = 220 - (v - 150) * (200/(300-150)) = 220 - (v-150)*1.333\n             2015: 180 → 220 - 30*1.333 = 220 - 40 = 180\n             2016: 192 → 220 - 42*1.333 = 220 - 56 = 164\n             2017: 205 → 220 - 55*1.333 = 220 - 73.3 = 146.7\n             2018: 220 → 220 - 70*1.333 = 220 - 93.3 = 126.7\n             2019: 231 → 220 - 81*1.333 = 220 - 108 = 112\n             2020: 218 → 220 - 68*1.333 = 220 - 90.7 = 129.3\n             2021: 248 → 220 - 98*1.333 = 220 - 130.7 = 89.3\n             2022: 264 → 220 - 114*1.333 = 220 - 152 = 68\n             2023: 280 → 220 - 130*1.333 = 220 - 173.3 = 46.7 (a bit high, let me reduce scale)\n        -->\n\n        <!-- Furniture market line (secondary) -->\n        <path d=\"M0,180 L80,164 L160,146.7 L240,126.7 L320,112 L400,129.3 L480,89.3 L560,68 L640,46.7 L720,30\" fill=\"url(#lineGrad2)\" opacity=\"0.5\"></path>\n        <path d=\"M0,180 L80,164 L160,146.7 L240,126.7 L320,112 L400,129.3 L480,89.3 L560,68 L640,46.7 L720,30\" stroke=\"#22d3ee\" stroke-width=\"1.5\" fill=\"none\" stroke-dasharray=\"5,3\" opacity=\"0.6\"></path>\n\n        <!-- Main market line (solid to 2023, dashed for 2024) -->\n        <path d=\"M0,187.5 L80,179 L160,166 L240,151.5 L320,142.5 L400,156 L480,117.5 L560,96 L640,76.5\" stroke=\"#f59e0b\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n        <!-- Projection 2024 -->\n        <path d=\"M640,76.5 L720,61\" stroke=\"#f59e0b\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-dasharray=\"5,4\"></path>\n\n        <!-- COVID annotation -->\n        <rect x=\"376\" y=\"140\" width=\"52\" height=\"22\" rx=\"4\" fill=\"rgba(248,113,113,0.15)\" stroke=\"rgba(248,113,113,0.3)\" stroke-width=\"1\"></rect>\n        <text x=\"402\" y=\"154\" fill=\"#f87171\" font-size=\"8\" text-anchor=\"middle\" font-family=\"Inter\">COVID dip</text>\n\n        <!-- 2024 projection badge -->\n        <rect x=\"672\" y=\"44\" width=\"46\" height=\"20\" rx=\"4\" fill=\"rgba(245,158,11,0.15)\" stroke=\"rgba(245,158,11,0.3)\" stroke-width=\"1\"></rect>\n        <text x=\"695\" y=\"57\" fill=\"#f59e0b\" font-size=\"8\" text-anchor=\"middle\" font-family=\"Inter\">2024E</text>\n\n        <!-- Data points -->\n        <circle cx=\"0\" cy=\"187.5\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"80\" cy=\"179\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"160\" cy=\"166\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"240\" cy=\"151.5\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"320\" cy=\"142.5\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"400\" cy=\"156\" r=\"5\" fill=\"rgba(248,113,113,0.3)\" stroke=\"#f87171\" stroke-width=\"2\"></circle>\n        <circle cx=\"480\" cy=\"117.5\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"560\" cy=\"96\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"640\" cy=\"76.5\" r=\"5\" fill=\"#f59e0b\" stroke=\"#f59e0b\" stroke-width=\"2\"></circle>\n        <circle cx=\"720\" cy=\"61\" r=\"4\" fill=\"#0a0d14\" stroke=\"#f59e0b\" stroke-width=\"2\" stroke-dasharray=\"3,2\"></circle>\n\n        <!-- Value labels on key points -->\n        <text x=\"0\" y=\"204\" fill=\"#94a3b8\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">$415B</text>\n        <text x=\"400\" y=\"173\" fill=\"#f87171\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">$478B</text>\n        <text x=\"640\" y=\"93\" fill=\"#f59e0b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">$637B</text>\n        <text x=\"720\" y=\"78\" fill=\"#f59e0b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">$668B</text>\n\n        <!-- X labels -->\n        <text x=\"0\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2015</text>\n        <text x=\"80\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2016</text>\n        <text x=\"160\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2017</text>\n        <text x=\"240\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2018</text>\n        <text x=\"320\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2019</text>\n        <text x=\"400\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2020</text>\n        <text x=\"480\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2021</text>\n        <text x=\"560\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2022</text>\n        <text x=\"640\" y=\"238\" fill=\"#64748b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\">2023</text>\n        <text x=\"720\" y=\"238\" fill=\"#94a3b8\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-style=\"italic\">2024E</text>\n      </svg>",
