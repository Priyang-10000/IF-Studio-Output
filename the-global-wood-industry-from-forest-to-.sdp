                            "svgText": "<svg width=\"140\" height=\"140\" viewBox=\"0 0 140 140\">\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"var(--surface3)\" stroke-width=\"20\"></circle>\n          <!-- Agriculture: 46% = 0.46 * 2π * 52 = 150.5 -->\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"#f87171\" stroke-width=\"20\" stroke-dasharray=\"150.5 326.7\" stroke-dashoffset=\"81.7\" transform=\"rotate(-90 70 70)\"></circle>\n          <!-- Livestock: 27% = 88.2 -->\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"20\" stroke-dasharray=\"88.2 326.7\" stroke-dashoffset=\"-68.8\" transform=\"rotate(-90 70 70)\"></circle>\n          <!-- Logging: 14% = 45.7 -->\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"#22d3ee\" stroke-width=\"20\" stroke-dasharray=\"45.7 326.7\" stroke-dashoffset=\"-157\" transform=\"rotate(-90 70 70)\"></circle>\n          <!-- Wildfire: 8% = 26.1 -->\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"#a78bfa\" stroke-width=\"20\" stroke-dasharray=\"26.1 326.7\" stroke-dashoffset=\"-202.7\" transform=\"rotate(-90 70 70)\"></circle>\n          <!-- Mining/Other: 5% = 16.3 -->\n          <circle cx=\"70\" cy=\"70\" r=\"52\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"20\" stroke-dasharray=\"16.3 326.7\" stroke-dashoffset=\"-228.8\" transform=\"rotate(-90 70 70)\"></circle>\n          <circle cx=\"70\" cy=\"70\" r=\"42\" fill=\"var(--surface)\"></circle>\n        </svg>",
