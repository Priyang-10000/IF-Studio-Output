                        "type": "svg",
                        "id": "tag504",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"180\" height=\"160\" viewBox=\"0 0 180 160\">\n        <!-- Central circle -->\n        <circle cx=\"90\" cy=\"80\" r=\"30\" fill=\"rgba(74,222,128,0.1)\" stroke=\"#4ade80\" stroke-width=\"1.5\"></circle>\n        <text x=\"90\" y=\"76\" fill=\"#4ade80\" font-size=\"9\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">SUSTAIN</text>\n        <text x=\"90\" y=\"88\" fill=\"#4ade80\" font-size=\"9\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">ABILITY</text>\n\n        <!-- Surrounding nodes -->\n        <!-- FSC -->\n        <circle cx=\"90\" cy=\"22\" r=\"18\" fill=\"rgba(74,222,128,0.08)\" stroke=\"rgba(74,222,128,0.3)\" stroke-width=\"1\"></circle>\n        <text x=\"90\" y=\"18\" fill=\"#94a3b8\" font-size=\"7.5\" text-anchor=\"middle\" font-family=\"Inter\">FSC</text>\n        <text x=\"90\" y=\"28\" fill=\"#4ade80\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">220Mha</text>\n        <line x1=\"90\" y1=\"40\" x2=\"90\" y2=\"50\" stroke=\"rgba(74,222,128,0.3)\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n\n        <!-- PEFC -->\n        <circle cx=\"162\" cy=\"55\" r=\"18\" fill=\"rgba(34,211,238,0.08)\" stroke=\"rgba(34,211,238,0.3)\" stroke-width=\"1\"></circle>\n        <text x=\"162\" y=\"51\" fill=\"#94a3b8\" font-size=\"7.5\" text-anchor=\"middle\" font-family=\"Inter\">PEFC</text>\n        <text x=\"162\" y=\"61\" fill=\"#22d3ee\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">320Mha</text>\n        <line x1=\"147\" y1=\"62\" x2=\"119\" y2=\"70\" stroke=\"rgba(34,211,238,0.3)\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n\n        <!-- Carbon -->\n        <circle cx=\"148\" cy=\"128\" r=\"18\" fill=\"rgba(245,158,11,0.08)\" stroke=\"rgba(245,158,11,0.3)\" stroke-width=\"1\"></circle>\n        <text x=\"148\" y=\"124\" fill=\"#94a3b8\" font-size=\"7.5\" text-anchor=\"middle\" font-family=\"Inter\">Carbon</text>\n        <text x=\"148\" y=\"134\" fill=\"#f59e0b\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">Credits</text>\n        <line x1=\"132\" y1=\"118\" x2=\"112\" y2=\"102\" stroke=\"rgba(245,158,11,0.3)\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n\n        <!-- Reforestation -->\n        <circle cx=\"32\" cy=\"128\" r=\"18\" fill=\"rgba(167,139,250,0.08)\" stroke=\"rgba(167,139,250,0.3)\" stroke-width=\"1\"></circle>\n        <text x=\"32\" y=\"124\" fill=\"#94a3b8\" font-size=\"7.5\" text-anchor=\"middle\" font-family=\"Inter\">Refore-</text>\n        <text x=\"32\" y=\"134\" fill=\"#a78bfa\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">station</text>\n        <line x1=\"48\" y1=\"118\" x2=\"68\" y2=\"102\" stroke=\"rgba(167,139,250,0.3)\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n\n        <!-- Biodiversity -->\n        <circle cx=\"18\" cy=\"55\" r=\"18\" fill=\"rgba(248,113,113,0.08)\" stroke=\"rgba(248,113,113,0.3)\" stroke-width=\"1\"></circle>\n        <text x=\"18\" y=\"51\" fill=\"#94a3b8\" font-size=\"7.5\" text-anchor=\"middle\" font-family=\"Inter\">Biodiv.</text>\n        <text x=\"18\" y=\"61\" fill=\"#f87171\" font-size=\"8.5\" text-anchor=\"middle\" font-family=\"Inter\" font-weight=\"700\">Protect</text>\n        <line x1=\"33\" y1=\"62\" x2=\"61\" y2=\"70\" stroke=\"rgba(248,113,113,0.3)\" stroke-width=\"1\" stroke-dasharray=\"3,2\"></line>\n      </svg>",
