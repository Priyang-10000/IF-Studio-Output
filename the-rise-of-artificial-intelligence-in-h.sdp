                        "svgText": "<svg viewBox=\"0 0 700 160\" width=\"100%\" height=\"160\" style=\"max-width:700px;\">\n        <!-- Neural network nodes -->\n        <defs>\n          <radialGradient id=\"nodeGlow1\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.8\"></stop>\n            <stop offset=\"100%\" stop-color=\"#00d4ff\" stop-opacity=\"0\"></stop>\n          </radialGradient>\n          <radialGradient id=\"nodeGlow2\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#7c3aed\" stop-opacity=\"0.8\"></stop>\n            <stop offset=\"100%\" stop-color=\"#7c3aed\" stop-opacity=\"0\"></stop>\n          </radialGradient>\n          <radialGradient id=\"nodeGlow3\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#10b981\" stop-opacity=\"0.8\"></stop>\n            <stop offset=\"100%\" stop-color=\"#10b981\" stop-opacity=\"0\"></stop>\n          </radialGradient>\n        </defs>\n\n        <!-- Layer 1 connections -->\n        <line x1=\"80\" y1=\"80\" x2=\"220\" y2=\"40\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"80\" y1=\"80\" x2=\"220\" y2=\"80\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"80\" y1=\"80\" x2=\"220\" y2=\"120\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"80\" y1=\"40\" x2=\"220\" y2=\"40\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"80\" y1=\"40\" x2=\"220\" y2=\"80\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"80\" y1=\"120\" x2=\"220\" y2=\"40\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"80\" y1=\"120\" x2=\"220\" y2=\"80\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"80\" y1=\"120\" x2=\"220\" y2=\"120\" stroke=\"#00d4ff\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n\n        <!-- Layer 2 connections -->\n        <line x1=\"220\" y1=\"40\" x2=\"380\" y2=\"30\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"220\" y1=\"40\" x2=\"380\" y2=\"70\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"220\" y1=\"40\" x2=\"380\" y2=\"110\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"220\" y1=\"40\" x2=\"380\" y2=\"140\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"220\" y1=\"80\" x2=\"380\" y2=\"30\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"220\" y1=\"80\" x2=\"380\" y2=\"70\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"220\" y1=\"80\" x2=\"380\" y2=\"110\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"220\" y1=\"80\" x2=\"380\" y2=\"140\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"220\" y1=\"120\" x2=\"380\" y2=\"70\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"220\" y1=\"120\" x2=\"380\" y2=\"110\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"220\" y1=\"120\" x2=\"380\" y2=\"140\" stroke=\"#7c3aed\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n\n        <!-- Layer 3 connections -->\n        <line x1=\"380\" y1=\"30\" x2=\"540\" y2=\"50\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"380\" y1=\"30\" x2=\"540\" y2=\"110\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"380\" y1=\"70\" x2=\"540\" y2=\"50\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"380\" y1=\"70\" x2=\"540\" y2=\"110\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"380\" y1=\"110\" x2=\"540\" y2=\"50\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n        <line x1=\"380\" y1=\"110\" x2=\"540\" y2=\"110\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.25\"></line>\n        <line x1=\"380\" y1=\"140\" x2=\"540\" y2=\"50\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.15\"></line>\n        <line x1=\"380\" y1=\"140\" x2=\"540\" y2=\"110\" stroke=\"#10b981\" stroke-width=\"0.8\" stroke-opacity=\"0.2\"></line>\n\n        <!-- Layer 4 connections -->\n        <line x1=\"540\" y1=\"50\" x2=\"660\" y2=\"80\" stroke=\"#f59e0b\" stroke-width=\"1\" stroke-opacity=\"0.4\"></line>\n        <line x1=\"540\" y1=\"110\" x2=\"660\" y2=\"80\" stroke=\"#f59e0b\" stroke-width=\"1\" stroke-opacity=\"0.4\"></line>\n\n        <!-- Nodes Layer 1 -->\n        <circle cx=\"80\" cy=\"40\" r=\"20\" fill=\"#00d4ff\" fill-opacity=\"0.05\"></circle>\n        <circle cx=\"80\" cy=\"40\" r=\"7\" fill=\"#00d4ff\" fill-opacity=\"0.8\"></circle>\n        <circle cx=\"80\" cy=\"40\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <circle cx=\"80\" cy=\"80\" r=\"20\" fill=\"#00d4ff\" fill-opacity=\"0.05\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"8\" fill=\"#00d4ff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <circle cx=\"80\" cy=\"120\" r=\"20\" fill=\"#00d4ff\" fill-opacity=\"0.05\"></circle>\n        <circle cx=\"80\" cy=\"120\" r=\"7\" fill=\"#00d4ff\" fill-opacity=\"0.8\"></circle>\n        <circle cx=\"80\" cy=\"120\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <!-- Nodes Layer 2 -->\n        <circle cx=\"220\" cy=\"40\" r=\"6\" fill=\"#7c3aed\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"220\" cy=\"40\" r=\"3\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"220\" cy=\"80\" r=\"8\" fill=\"#7c3aed\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"220\" cy=\"80\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"220\" cy=\"120\" r=\"6\" fill=\"#7c3aed\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"220\" cy=\"120\" r=\"3\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <!-- Nodes Layer 3 -->\n        <circle cx=\"380\" cy=\"30\" r=\"6\" fill=\"#ec4899\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"30\" r=\"3\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"70\" r=\"7\" fill=\"#ec4899\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"70\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"110\" r=\"7\" fill=\"#ec4899\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"110\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"140\" r=\"5\" fill=\"#ec4899\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"380\" cy=\"140\" r=\"3\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <!-- Nodes Layer 4 -->\n        <circle cx=\"540\" cy=\"50\" r=\"22\" fill=\"#10b981\" fill-opacity=\"0.06\"></circle>\n        <circle cx=\"540\" cy=\"50\" r=\"8\" fill=\"#10b981\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"540\" cy=\"50\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"540\" cy=\"110\" r=\"22\" fill=\"#10b981\" fill-opacity=\"0.06\"></circle>\n        <circle cx=\"540\" cy=\"110\" r=\"8\" fill=\"#10b981\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"540\" cy=\"110\" r=\"4\" fill=\"#fff\" fill-opacity=\"0.9\"></circle>\n\n        <!-- Output Node -->\n        <circle cx=\"660\" cy=\"80\" r=\"28\" fill=\"#f59e0b\" fill-opacity=\"0.08\"></circle>\n        <circle cx=\"660\" cy=\"80\" r=\"16\" fill=\"#f59e0b\" fill-opacity=\"0.15\"></circle>\n        <circle cx=\"660\" cy=\"80\" r=\"10\" fill=\"#f59e0b\" fill-opacity=\"0.9\"></circle>\n        <circle cx=\"660\" cy=\"80\" r=\"5\" fill=\"#fff\" fill-opacity=\"0.95\"></circle>\n\n        <!-- Labels -->\n        <text x=\"80\" y=\"152\" font-family=\"Inter\" font-size=\"10\" fill=\"#4a5568\" text-anchor=\"middle\">Input</text>\n        <text x=\"220\" y=\"152\" font-family=\"Inter\" font-size=\"10\" fill=\"#4a5568\" text-anchor=\"middle\">Hidden L1</text>\n        <text x=\"380\" y=\"158\" font-family=\"Inter\" font-size=\"10\" fill=\"#4a5568\" text-anchor=\"middle\">Hidden L2</text>\n        <text x=\"540\" y=\"145\" font-family=\"Inter\" font-size=\"10\" fill=\"#4a5568\" text-anchor=\"middle\">Hidden L3</text>\n        <text x=\"660\" y=\"115\" font-family=\"Inter\" font-size=\"10\" fill=\"#f59e0b\" text-anchor=\"middle\">Output</text>\n\n        <text x=\"350\" y=\"16\" font-family=\"Inter\" font-size=\"13\" font-weight=\"700\" fill=\"#f0f4ff\" text-anchor=\"middle\" opacity=\"0.5\">Neural Network Architecture — Healthcare AI Model</text>\n      </svg>",
