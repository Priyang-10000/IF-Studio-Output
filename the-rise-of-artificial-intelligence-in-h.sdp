                          {
                            "type": "svg",
                            "id": "tag77",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 520 320\" width=\"100%\" height=\"320\">\n          <!-- Grid lines -->\n          <line x1=\"60\" y1=\"20\" x2=\"60\" y2=\"260\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n          <line x1=\"60\" y1=\"260\" x2=\"510\" y2=\"260\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n          <line x1=\"60\" y1=\"220\" x2=\"510\" y2=\"220\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"4,3\"></line>\n          <line x1=\"60\" y1=\"180\" x2=\"510\" y2=\"180\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"4,3\"></line>\n          <line x1=\"60\" y1=\"140\" x2=\"510\" y2=\"140\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"4,3\"></line>\n          <line x1=\"60\" y1=\"100\" x2=\"510\" y2=\"100\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"4,3\"></line>\n          <line x1=\"60\" y1=\"60\" x2=\"510\" y2=\"60\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"4,3\"></line>\n\n          <!-- Y axis labels -->\n          <text x=\"50\" y=\"264\" class=\"axis-text\" text-anchor=\"end\">0</text>\n          <text x=\"50\" y=\"224\" class=\"axis-text\" text-anchor=\"end\">5</text>\n          <text x=\"50\" y=\"184\" class=\"axis-text\" text-anchor=\"end\">10</text>\n          <text x=\"50\" y=\"144\" class=\"axis-text\" text-anchor=\"end\">15</text>\n          <text x=\"50\" y=\"104\" class=\"axis-text\" text-anchor=\"end\">20</text>\n          <text x=\"50\" y=\"64\" class=\"axis-text\" text-anchor=\"end\">25</text>\n\n          <!-- Bars: values in billions: 2019:4.9, 2020:6.6, 2021:9.5, 2022:14.2, 2023:19.3, 2024:26.1 -->\n          <!-- Scale: 25B = 200px, so 1B = 8px, y = 260 - val*8 -->\n          <!-- 2019: 4.9*8=39.2, y=220.8 -->\n          <g class=\"bar-group\">\n            <defs>\n              <linearGradient id=\"bar1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#00d4ff\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n              <linearGradient id=\"bar2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#3b82f6\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#3b82f6\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n              <linearGradient id=\"bar3\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#7c3aed\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#7c3aed\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n              <linearGradient id=\"bar4\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#a855f7\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#a855f7\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n              <linearGradient id=\"bar5\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#ec4899\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#ec4899\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n              <linearGradient id=\"bar6\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#f59e0b\" stop-opacity=\"0.9\"></stop>\n                <stop offset=\"100%\" stop-color=\"#f59e0b\" stop-opacity=\"0.3\"></stop>\n              </linearGradient>\n            </defs>\n            <rect x=\"80\" y=\"220.8\" width=\"50\" height=\"39.2\" rx=\"4\" fill=\"url(#bar1)\"></rect>\n            <text x=\"105\" y=\"215\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#00d4ff\">4.9</text>\n          </g>\n          <g class=\"bar-group\">\n            <rect x=\"160\" y=\"207.2\" width=\"50\" height=\"52.8\" rx=\"4\" fill=\"url(#bar2)\"></rect>\n            <text x=\"185\" y=\"201\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#3b82f6\">6.6</text>\n          </g>\n          <g class=\"bar-group\">\n            <rect x=\"240\" y=\"184\" width=\"50\" height=\"76\" rx=\"4\" fill=\"url(#bar3)\"></rect>\n            <text x=\"265\" y=\"178\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#7c3aed\">9.5</text>\n          </g>\n          <g class=\"bar-group\">\n            <rect x=\"320\" y=\"146.4\" width=\"50\" height=\"113.6\" rx=\"4\" fill=\"url(#bar4)\"></rect>\n            <text x=\"345\" y=\"140\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#a855f7\">14.2</text>\n          </g>\n          <g class=\"bar-group\">\n            <rect x=\"400\" y=\"105.6\" width=\"50\" height=\"154.4\" rx=\"4\" fill=\"url(#bar5)\"></rect>\n            <text x=\"425\" y=\"99\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#ec4899\">19.3</text>\n          </g>\n          <g class=\"bar-group\">\n            <rect x=\"480\" y=\"51.2\" width=\"50\" height=\"208.8\" rx=\"4\" fill=\"url(#bar6)\"></rect>\n            <text x=\"505\" y=\"45\" class=\"axis-text\" text-anchor=\"middle\" fill=\"#f59e0b\">26.1</text>\n          </g>\n\n          <!-- X axis labels -->\n          <text x=\"105\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2019</text>\n          <text x=\"185\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2020</text>\n          <text x=\"265\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2021</text>\n          <text x=\"345\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2022</text>\n          <text x=\"425\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2023</text>\n          <text x=\"505\" y=\"280\" class=\"axis-text\" text-anchor=\"middle\">2024</text>\n\n          <!-- trend line -->\n          <polyline points=\"105,220.8 185,207.2 265,184 345,146.4 425,105.6 505,51.2\" fill=\"none\" stroke=\"#ffffff\" stroke-width=\"1\" stroke-dasharray=\"4,4\" stroke-opacity=\"0.15\"></polyline>\n        </svg>",
