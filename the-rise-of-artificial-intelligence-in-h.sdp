                            "id": "tag114",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 520 300\" width=\"100%\" height=\"300\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.3\"></stop>\n              <stop offset=\"100%\" stop-color=\"#00d4ff\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#10b981\" stop-opacity=\"0.3\"></stop>\n              <stop offset=\"100%\" stop-color=\"#10b981\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Grid -->\n          <line x1=\"50\" y1=\"20\" x2=\"50\" y2=\"250\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"250\" x2=\"510\" y2=\"250\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"210\" x2=\"510\" y2=\"210\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"170\" x2=\"510\" y2=\"170\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"130\" x2=\"510\" y2=\"130\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"90\" x2=\"510\" y2=\"90\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"50\" x2=\"510\" y2=\"50\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n\n          <text x=\"40\" y=\"254\" class=\"axis-text-sm\" text-anchor=\"end\">0</text>\n          <text x=\"40\" y=\"214\" class=\"axis-text-sm\" text-anchor=\"end\">50</text>\n          <text x=\"40\" y=\"174\" class=\"axis-text-sm\" text-anchor=\"end\">100</text>\n          <text x=\"40\" y=\"134\" class=\"axis-text-sm\" text-anchor=\"end\">150</text>\n          <text x=\"40\" y=\"94\" class=\"axis-text-sm\" text-anchor=\"end\">200</text>\n          <text x=\"40\" y=\"54\" class=\"axis-text-sm\" text-anchor=\"end\">250</text>\n\n          <!-- Annual approvals data: 2017:6, 2018:29, 2019:40, 2020:91, 2021:98, 2022:139, 2023:171 -->\n          <!-- Scale: 250 max = 200px. 1 unit = 0.8px. y = 250 - val*0.8 -->\n          <!-- x positions: 2017=82, 2018=150, 2019=218, 2020=286, 2021=354, 2022=422, 2023=490 -->\n\n          <!-- Area fill for annual -->\n          <path d=\"M 82,245.2 L 150,226.8 L 218,218 L 286,177.2 L 354,171.6 L 422,138.8 L 490,113.2 L 490,250 L 82,250 Z\" fill=\"url(#lineGrad)\"></path>\n\n          <!-- Line: Annual -->\n          <polyline points=\"82,245.2 150,226.8 218,218 286,177.2 354,171.6 422,138.8 490,113.2\" fill=\"none\" stroke=\"#00d4ff\" stroke-width=\"2.5\"></polyline>\n\n          <!-- Dots: Annual -->\n          <circle cx=\"82\" cy=\"245.2\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"150\" cy=\"226.8\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"218\" cy=\"218\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"286\" cy=\"177.2\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"354\" cy=\"171.6\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"422\" cy=\"138.8\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n          <circle cx=\"490\" cy=\"113.2\" r=\"4\" fill=\"#00d4ff\" stroke=\"#050810\" stroke-width=\"2\"></circle>\n\n          <!-- Value labels -->\n          <text x=\"82\" y=\"238\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">6</text>\n          <text x=\"150\" y=\"219\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">29</text>\n          <text x=\"218\" y=\"210\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">40</text>\n          <text x=\"286\" y=\"169\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">91</text>\n          <text x=\"354\" y=\"163\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">98</text>\n          <text x=\"422\" y=\"130\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">139</text>\n          <text x=\"490\" y=\"105\" class=\"axis-text-sm\" text-anchor=\"middle\" fill=\"#00d4ff\">171</text>\n\n          <!-- X axis -->\n          <text x=\"82\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2017</text>\n          <text x=\"150\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2018</text>\n          <text x=\"218\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2019</text>\n          <text x=\"286\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2020</text>\n          <text x=\"354\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2021</text>\n          <text x=\"422\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2022</text>\n          <text x=\"490\" y=\"268\" class=\"axis-text-sm\" text-anchor=\"middle\">2023</text>\n\n          <!-- Legend -->\n          <line x1=\"60\" y1=\"35\" x2=\"80\" y2=\"35\" stroke=\"#00d4ff\" stroke-width=\"2.5\"></line>\n          <circle cx=\"70\" cy=\"35\" r=\"3\" fill=\"#00d4ff\"></circle>\n          <text x=\"86\" y=\"39\" font-family=\"Inter\" font-size=\"11\" fill=\"#8892b0\">Annual Approvals</text>\n        </svg>",
