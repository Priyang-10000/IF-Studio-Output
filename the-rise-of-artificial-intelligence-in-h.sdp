                            "id": "tag118",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 520 300\" width=\"100%\" height=\"300\">\n          <defs>\n            <linearGradient id=\"hbar1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#00d4ff\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#3b82f6\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n            <linearGradient id=\"hbar2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#7c3aed\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#a855f7\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n            <linearGradient id=\"hbar3\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#10b981\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#34d399\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n            <linearGradient id=\"hbar4\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#f59e0b\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#fbbf24\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n            <linearGradient id=\"hbar5\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#ec4899\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#f472b6\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n            <linearGradient id=\"hbar6\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#6366f1\" stop-opacity=\"0.9\"></stop>\n              <stop offset=\"100%\" stop-color=\"#818cf8\" stop-opacity=\"0.7\"></stop>\n            </linearGradient>\n          </defs>\n\n          <!-- Vertical grid line at 100% -->\n          <line x1=\"170\" y1=\"10\" x2=\"170\" y2=\"280\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n          <line x1=\"290\" y1=\"10\" x2=\"290\" y2=\"280\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"410\" y1=\"10\" x2=\"410\" y2=\"280\" stroke=\"#1e2a45\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"170\" y1=\"280\" x2=\"510\" y2=\"280\" stroke=\"#1e2a45\" stroke-width=\"1\"></line>\n\n          <!-- X axis labels: 0%, 25%, 50%, 75% -->\n          <text x=\"170\" y=\"295\" class=\"axis-text-sm\" text-anchor=\"middle\">0%</text>\n          <text x=\"290\" y=\"295\" class=\"axis-text-sm\" text-anchor=\"middle\">25%</text>\n          <text x=\"410\" y=\"295\" class=\"axis-text-sm\" text-anchor=\"middle\">50%</text>\n          <text x=\"510\" y=\"295\" class=\"axis-text-sm\" text-anchor=\"middle\">67%</text>\n\n          <!-- Scale: 67% max mapped to 340px (170 to 510). 1% = 340/67 = 5.07px -->\n\n          <!-- Radiology: 67% -->\n          <text x=\"160\" y=\"42\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Radiology</text>\n          <rect x=\"170\" y=\"30\" width=\"340\" height=\"18\" rx=\"4\" fill=\"url(#hbar1)\"></rect>\n          <text x=\"518\" y=\"43\" class=\"value-text\" fill=\"#00d4ff\" font-size=\"12\">67%</text>\n\n          <!-- Pathology: 55% -->\n          <text x=\"160\" y=\"84\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Pathology</text>\n          <rect x=\"170\" y=\"72\" width=\"278.9\" height=\"18\" rx=\"4\" fill=\"url(#hbar2)\"></rect>\n          <text x=\"518\" y=\"85\" class=\"value-text\" fill=\"#7c3aed\" font-size=\"12\">55%</text>\n\n          <!-- Oncology: 49% -->\n          <text x=\"160\" y=\"126\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Oncology</text>\n          <rect x=\"170\" y=\"114\" width=\"248.5\" height=\"18\" rx=\"4\" fill=\"url(#hbar3)\"></rect>\n          <text x=\"518\" y=\"127\" class=\"value-text\" fill=\"#10b981\" font-size=\"12\">49%</text>\n\n          <!-- Cardiology: 43% -->\n          <text x=\"160\" y=\"168\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Cardiology</text>\n          <rect x=\"170\" y=\"156\" width=\"218.1\" height=\"18\" rx=\"4\" fill=\"url(#hbar4)\"></rect>\n          <text x=\"518\" y=\"169\" class=\"value-text\" fill=\"#f59e0b\" font-size=\"12\">43%</text>\n\n          <!-- Neurology: 38% -->\n          <text x=\"160\" y=\"210\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Neurology</text>\n          <rect x=\"170\" y=\"198\" width=\"192.7\" height=\"18\" rx=\"4\" fill=\"url(#hbar5)\"></rect>\n          <text x=\"518\" y=\"211\" class=\"value-text\" fill=\"#ec4899\" font-size=\"12\">38%</text>\n\n          <!-- Primary Care: 24% -->\n          <text x=\"160\" y=\"252\" class=\"label-text\" text-anchor=\"end\" font-size=\"12\">Primary Care</text>\n          <rect x=\"170\" y=\"240\" width=\"121.7\" height=\"18\" rx=\"4\" fill=\"url(#hbar6)\"></rect>\n          <text x=\"518\" y=\"253\" class=\"value-text\" fill=\"#6366f1\" font-size=\"12\">24%</text>\n        </svg>",
