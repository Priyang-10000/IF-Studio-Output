                          {
                            "type": "svg",
                            "id": "tag81",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 520 320\" width=\"100%\" height=\"320\">\n          <defs>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n          <!-- Donut segments: center at 190,160 r=110 inner=65 -->\n          <!-- Medical Imaging 32%, Drug Discovery 24%, Virtual Assistants 18%, Hospital Management 15%, Others 11% -->\n          <!-- 32% = 115.2deg, 24% = 86.4, 18% = 64.8, 15% = 54, 11% = 39.6 -->\n\n          <!-- Segment 1: Medical Imaging 32% - starts at -90deg (top) -->\n          <!-- -90 to 25.2 -->\n          <path d=\"M 190 160 L 190 50 A 110 110 0 0 1 302.4 194.6 Z\" fill=\"#00d4ff\" fill-opacity=\"0.85\" filter=\"url(#glow)\"></path>\n          <!-- Inner hole -->\n\n          <!-- Segment 2: Drug Discovery 24% - 25.2 to 111.6 -->\n          <path d=\"M 190 160 L 302.4 194.6 A 110 110 0 0 1 199.7 271.2 Z\" fill=\"#7c3aed\" fill-opacity=\"0.85\"></path>\n\n          <!-- Segment 3: Virtual Assistants 18% - 111.6 to 176.4 -->\n          <path d=\"M 190 160 L 199.7 271.2 A 110 110 0 0 1 80.1 218.5 Z\" fill=\"#10b981\" fill-opacity=\"0.85\"></path>\n\n          <!-- Segment 4: Hospital Mgmt 15% - 176.4 to 230.4 -->\n          <path d=\"M 190 160 L 80.1 218.5 A 110 110 0 0 1 79.1 104.8 Z\" fill=\"#f59e0b\" fill-opacity=\"0.85\"></path>\n\n          <!-- Segment 5: Others 11% - 230.4 to 270 -->\n          <path d=\"M 190 160 L 79.1 104.8 A 110 110 0 0 1 190 50 Z\" fill=\"#ec4899\" fill-opacity=\"0.85\"></path>\n\n          <!-- Inner circle (donut hole) -->\n          <circle cx=\"190\" cy=\"160\" r=\"65\" fill=\"#0d1426\"></circle>\n\n          <!-- Center text -->\n          <text x=\"190\" y=\"153\" text-anchor=\"middle\" font-family=\"JetBrains Mono\" font-size=\"22\" font-weight=\"900\" fill=\"#f0f4ff\">2023</text>\n          <text x=\"190\" y=\"172\" text-anchor=\"middle\" font-family=\"Inter\" font-size=\"11\" fill=\"#4a5568\">Market</text>\n\n          <!-- Connector lines and labels -->\n          <line x1=\"250\" y1=\"90\" x2=\"280\" y2=\"70\" stroke=\"#00d4ff\" stroke-width=\"1\" stroke-opacity=\"0.5\"></line>\n          <text x=\"284\" y=\"62\" font-family=\"Inter\" font-size=\"12\" font-weight=\"700\" fill=\"#00d4ff\">Medical Imaging</text>\n          <text x=\"284\" y=\"75\" font-family=\"JetBrains Mono\" font-size=\"11\" fill=\"#4a5568\">32%</text>\n\n          <line x1=\"280\" y1=\"220\" x2=\"310\" y2=\"235\" stroke=\"#7c3aed\" stroke-width=\"1\" stroke-opacity=\"0.5\"></line>\n          <text x=\"314\" y=\"228\" font-family=\"Inter\" font-size=\"12\" font-weight=\"700\" fill=\"#7c3aed\">Drug Discovery</text>\n          <text x=\"314\" y=\"241\" font-family=\"JetBrains Mono\" font-size=\"11\" fill=\"#4a5568\">24%</text>\n\n          <line x1=\"120\" y1=\"258\" x2=\"100\" y2=\"280\" stroke=\"#10b981\" stroke-width=\"1\" stroke-opacity=\"0.5\"></line>\n          <text x=\"22\" y=\"280\" font-family=\"Inter\" font-size=\"12\" font-weight=\"700\" fill=\"#10b981\">Virtual Assist.</text>\n          <text x=\"22\" y=\"293\" font-family=\"JetBrains Mono\" font-size=\"11\" fill=\"#4a5568\">18%</text>\n\n          <line x1=\"75\" y1=\"160\" x2=\"44\" y2=\"155\" stroke=\"#f59e0b\" stroke-width=\"1\" stroke-opacity=\"0.5\"></line>\n          <text x=\"10\" y=\"145\" font-family=\"Inter\" font-size=\"12\" font-weight=\"700\" fill=\"#f59e0b\">Hosp. Mgmt</text>\n          <text x=\"10\" y=\"158\" font-family=\"JetBrains Mono\" font-size=\"11\" fill=\"#4a5568\">15%</text>\n\n          <line x1=\"120\" y1=\"65\" x2=\"100\" y2=\"48\" stroke=\"#ec4899\" stroke-width=\"1\" stroke-opacity=\"0.5\"></line>\n          <text x=\"28\" y=\"40\" font-family=\"Inter\" font-size=\"12\" font-weight=\"700\" fill=\"#ec4899\">Others</text>\n          <text x=\"28\" y=\"53\" font-family=\"JetBrains Mono\" font-size=\"11\" fill=\"#4a5568\">11%</text>\n        </svg>",
